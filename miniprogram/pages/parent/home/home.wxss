/* ============================================================
 *  parent/home — 家长端首页(给客户看的脸,需精致)
 *  设计系统 V1.0
 * ============================================================ */

/* === 加载状态(避免空白) === */
.container > .empty-state {
  padding: 120px 22px;
}

.container > .empty-state::before {
  content: "·";
  display: block;
  font-size: 40px;
  color: var(--ink-mute);
  line-height: 1;
  margin-bottom: 12px;
  animation: pulse 1.4s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

/* === 问候语(家长版,比老师端柔和一些) === */
.greeting {
  padding: 8px 0 20px;
}

.greeting-text {
  font-family: var(--font-serif);
  font-size: 26px;
  font-weight: 500;
  color: var(--ink);
  letter-spacing: -0.3px;
  line-height: 1.35;
  display: block;
}

/* ============================================================
 *  学员概览卡(家长端的"主数据卡" — 深色 ink 背景突出剩余课时)
 * ============================================================ */
.container > .card:first-of-type {
  background: var(--ink);
  color: var(--paper);
  border: 1px solid var(--ink);
  border-radius: 20px;
  padding: 20px 22px;
  position: relative;
  overflow: hidden;
  margin-bottom: 22px;
}

/* 右上装饰光斑 */
.container > .card:first-of-type::before {
  content: "";
  position: absolute;
  right: -30px;
  top: -30px;
  width: 140px;
  height: 140px;
  background: radial-gradient(circle, rgba(191, 209, 229, 0.18) 0%, transparent 70%);
  pointer-events: none;
}

.student-overview {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
  position: relative;
  z-index: 1;
}

.student-overview .avatar {
  width: 56px;
  height: 56px;
  border-radius: 18px;
  background: linear-gradient(135deg, var(--accent-mid), var(--accent));
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-serif);
  font-size: 22px;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 4px 12px -4px rgba(0, 0, 0, 0.3);
}

.overview-info {
  flex: 1;
  margin-left: 16px;
  min-width: 0;
}

.student-name {
  font-family: var(--font-serif);
  font-size: 20px;
  font-weight: 500;
  letter-spacing: 0.5px;
  color: var(--paper);
  display: block;
  margin-bottom: 14px;
}

.stats-row {
  display: flex;
  gap: 32px;
}

.stat {
  text-align: left;
}

.stat-value {
  font-family: var(--font-num);
  font-size: 36px;
  font-weight: 400;
  letter-spacing: -1px;
  color: var(--paper);
  display: block;
  line-height: 1;
}

.stat-value.warning {
  color: #FED7AA;
}

.stat-value.danger {
  color: #FDBA74;
}

.stat-label {
  font-family: var(--font-mono);
  font-size: 10px;
  color: rgba(244, 247, 250, 0.55);
  letter-spacing: 1.5px;
  text-transform: uppercase;
  margin-top: 6px;
  display: block;
}

.warning-tip {
  margin-top: 16px;
  padding-top: 14px;
  border-top: 1px solid rgba(244, 247, 250, 0.1);
  position: relative;
  z-index: 1;
}

.warning-tip .tag-danger {
  background: rgba(254, 215, 170, 0.15);
  color: #FED7AA;
  border: 1px solid rgba(253, 186, 116, 0.3);
  padding: 6px 12px;
  border-radius: 100px;
  font-size: 11px;
  letter-spacing: 0.3px;
}

/* ============================================================
 *  下次上课(突出展示)
 * ============================================================ */
.section .card {
  position: relative;
  overflow: hidden;
}

/* 下次上课卡左侧蓝色色条 */
.section:nth-of-type(1) .card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4px;
  background: linear-gradient(180deg, var(--accent) 0%, var(--accent-mid) 100%);
}

.section:nth-of-type(1) .card {
  padding-left: 20px;
}

.schedule-time {
  font-family: var(--font-num);
  font-size: 18px;
  color: var(--ink);
  display: block;
  letter-spacing: -0.3px;
  line-height: 1.3;
  margin-bottom: 4px;
}

.schedule-classroom {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-soft);
  display: block;
  letter-spacing: 0.5px;
  margin-top: 4px;
}

/* ============================================================
 *  最新反馈卡
 * ============================================================ */
.feedback-date {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--ink-mute);
  display: block;
  margin-bottom: 10px;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.feedback-comment {
  font-family: var(--font-serif);
  font-size: 14px;
  color: var(--ink);
  display: block;
  line-height: 1.7;
  letter-spacing: 0.2px;
  position: relative;
  padding-left: 14px;
}

/* 左侧引号装饰 */
.feedback-comment::before {
  content: "";
  position: absolute;
  left: 0;
  top: 3px;
  bottom: 3px;
  width: 2px;
  background: var(--accent-soft);
  border-radius: 1px;
}

.audio-hint {
  display: inline-flex;
  align-items: center;
  margin-top: 12px;
  background: var(--accent-bg);
  color: var(--accent);
  border: 1px solid var(--accent-soft);
  padding: 5px 10px;
  border-radius: 100px;
  font-size: 11px;
  font-weight: 500;
}

/* ============================================================
 *  快捷操作
 * ============================================================ */
.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10px;
}

.action-item {
  background: var(--cream);
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 16px 8px 14px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  box-shadow: none;
}

.action-item:active {
  background: var(--paper-warm);
}

.action-icon {
  width: 38px;
  height: 38px;
  background: var(--accent-bg);
  color: var(--accent);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  line-height: 1;
}

.action-text {
  font-size: 12px;
  font-weight: 500;
  color: var(--ink);
  letter-spacing: 0.5px;
}
