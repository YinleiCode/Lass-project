/* ============================================================
 *  parent/home — 家长端首页
 *  设计系统 V2.0 梅子弥散
 * ============================================================ */

/* === 加载状态(避免空白) === */
.container > .empty-state {
  padding: 240rpx 44rpx;
}

.container > .empty-state::before {
  content: "·";
  display: block;
  font-size: 80rpx;
  color: var(--ink-mute);
  line-height: 1;
  margin-bottom: 24rpx;
  animation: pulse 1.4s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

/* === 问候语(家长版,比老师端柔和一些) === */
.greeting {
  padding: 8rpx 0 28rpx;
}

.greeting-text {
  font-family: var(--font-serif);
  font-size: 60rpx;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: 0;
  line-height: 1.02;
  display: block;
}

/* ============================================================
 *  V2 家长首屏: 梅子弥散 + 雾面插画
 * ============================================================ */
.parent-hero {
  position: relative;
  background:
    radial-gradient(circle at 78% 18%, rgba(237, 167, 219, 0.36) 0, transparent 250rpx),
    radial-gradient(circle at 16% 20%, rgba(255, 255, 255, 0.96) 0, transparent 250rpx),
    radial-gradient(circle at 20% 92%, rgba(244, 236, 242, 0.76) 0, transparent 300rpx),
    linear-gradient(150deg, rgba(255, 248, 252, 0.98), rgba(247, 250, 249, 0.84) 58%, rgba(251, 232, 245, 0.62));
  border-radius: 44rpx;
  min-height: 438rpx;
  margin: 0 0 24rpx;
  overflow: hidden;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.82), 0 20rpx 52rpx rgba(181, 107, 162, 0.08);
}

.parent-hero::before {
  content: "";
  position: absolute;
  left: -120rpx;
  top: 120rpx;
  width: 360rpx;
  height: 360rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.58);
  border-radius: 50%;
}

.parent-hero::after {
  content: "";
  position: absolute;
  right: 18rpx;
  top: 86rpx;
  width: 440rpx;
  height: 270rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 48% 42%, rgba(255, 255, 255, 0.66), transparent 62%),
    radial-gradient(circle, rgba(237, 167, 219, 0.24), transparent 70%);
  opacity: 0.72;
}

.parent-hero-top {
  position: absolute;
  top: 36rpx;
  left: 36rpx;
  right: 36rpx;
  z-index: 4;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.parent-kicker {
  color: rgba(72, 30, 58, 0.72);
  font-size: 20rpx;
  font-weight: 850;
  letter-spacing: 2.5rpx;
}

.parent-voice-art {
  position: absolute;
  left: 52%;
  top: 86rpx;
  transform: translateX(-50%);
  z-index: 2;
  width: 600rpx;
  height: 300rpx;
  opacity: 0.86;
  pointer-events: none;
}

.parent-caption {
  position: absolute;
  left: 30rpx;
  right: auto;
  bottom: 28rpx;
  z-index: 3;
  width: 468rpx;
  background: rgba(255, 255, 255, 0.44);
  border-radius: 28rpx;
  padding: 18rpx 22rpx 20rpx;
  backdrop-filter: blur(18rpx);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.36);
}

.parent-caption .art-kicker {
  margin-bottom: 7rpx;
  color: rgba(72, 30, 58, 0.60);
  letter-spacing: 2rpx;
}

.parent-caption .art-note {
  max-width: 410rpx;
  color: rgba(72, 30, 58, 0.74);
}

.student-main-card {
  position: relative;
  z-index: 2;
  margin-top: 0;
}

.parent-mood-panel {
  position: relative;
  z-index: 3;
  background:
    radial-gradient(circle at 84% 10%, rgba(237, 167, 219, 0.40) 0, transparent 240rpx),
    radial-gradient(circle at 14% 88%, rgba(255, 255, 255, 0.76) 0, transparent 250rpx),
    linear-gradient(145deg, rgba(255, 246, 252, 0.88), rgba(244, 233, 240, 0.78));
  color: var(--ink);
  border-radius: 42rpx;
  padding: 28rpx 24rpx 26rpx;
  margin: 0 0 34rpx;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.72), 0 18rpx 42rpx rgba(108, 45, 88, 0.08);
  overflow: hidden;
  backdrop-filter: blur(16rpx);
}

.parent-mood-panel::before {
  content: "";
  position: absolute;
  left: -120rpx;
  bottom: -160rpx;
  width: 380rpx;
  height: 380rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.50);
}

.mood-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
  position: relative;
  z-index: 1;
}

.mood-panel-head text:first-child {
  color: var(--ink);
  font-size: 32rpx;
  font-weight: 850;
  letter-spacing: 0;
}

.mood-panel-head text:last-child {
  color: var(--ink-mute);
  font-size: 23rpx;
}

.mood-days {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 8rpx;
  text-align: center;
  margin-bottom: 28rpx;
  position: relative;
  z-index: 1;
}

.mood-day {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  color: var(--ink-mute);
  font-size: 20rpx;
}

.mood-day text:first-child {
  color: var(--ink-soft);
  font-size: 34rpx;
  line-height: 1;
  font-weight: 850;
}

.mood-day.active text:first-child {
  color: var(--accent);
  font-size: 44rpx;
}

.mood-track {
  height: 4rpx;
  background: rgba(108, 45, 88, 0.12);
  border-radius: 999rpx;
  margin: 0 18rpx 28rpx;
  position: relative;
  z-index: 1;
}

.mood-track::after {
  content: "";
  position: absolute;
  right: 142rpx;
  top: 50%;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: var(--accent);
  transform: translateY(-50%);
}

.mood-tags {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  position: relative;
  z-index: 1;
}

.mood-tags text {
  height: 62rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 850;
}

.mood-tags .active {
  background:
    radial-gradient(circle at 34% 20%, rgba(255, 255, 255, 0.74), transparent 45%),
    rgba(237, 167, 219, 0.62);
}

/* ============================================================
 *  学员概览卡(家长端的主数据卡)
 * ============================================================ */
.container > .card:first-of-type,
.student-main-card {
  background:
    radial-gradient(circle at 88% -2%, rgba(237, 167, 219, 0.34) 0, transparent 230rpx),
    radial-gradient(circle at 10% 96%, rgba(255, 255, 255, 0.70) 0, transparent 260rpx),
    linear-gradient(145deg, rgba(255, 248, 252, 0.92), rgba(247, 238, 244, 0.82));
  color: var(--ink);
  border: none;
  border-radius: 36rpx;
  padding: 26rpx 28rpx 28rpx;
  position: relative;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.72), 0 16rpx 38rpx rgba(108, 45, 88, 0.06);
  backdrop-filter: blur(16rpx);
}

/* 右上装饰光斑 */
.container > .card:first-of-type::before {
  content: "";
  position: absolute;
  right: -60rpx;
  top: -60rpx;
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle, rgba(237, 167, 219, 0.42) 0%, transparent 70%);
  pointer-events: none;
}

.student-overview {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
  position: relative;
  z-index: 1;
}

.student-overview .avatar {
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  background: var(--accent);
  color: var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-serif);
  font-size: 34rpx;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 14rpx 28rpx -12rpx rgba(237, 167, 219, 0.6);
}

.overview-info {
  flex: 1;
  margin-left: 22rpx;
  min-width: 0;
}

.student-name {
  font-family: var(--font-serif);
  font-size: 32rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  color: var(--ink);
  display: block;
  margin-bottom: 14rpx;
}

.stats-row {
  display: grid;
  grid-template-columns: 0.86fr 0.86fr 1.42fr;
  gap: 12rpx;
  align-items: end;
}

.stat {
  text-align: left;
  min-width: 0;
}

.stat-value {
  font-family: var(--font-num);
  font-size: 46rpx;
  font-weight: 900;
  letter-spacing: 0;
  color: var(--ink);
  display: block;
  line-height: 1;
}

.money-value {
  font-size: 34rpx;
  letter-spacing: 0;
  word-break: break-all;
}

.stat-value.warning {
  color: var(--warn);
}

.stat-value.danger {
  color: var(--red);
}

.stat-label {
  font-family: var(--font-mono);
  font-size: 18rpx;
  color: var(--ink-mute);
  letter-spacing: 1rpx;
  text-transform: uppercase;
  margin-top: 9rpx;
  display: block;
}

.warning-tip {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid rgba(108, 45, 88, 0.08);
  position: relative;
  z-index: 1;
}

.warning-tip .tag-danger {
  background: rgba(237, 167, 219, 0.26);
  color: var(--ink);
  border: 2rpx solid rgba(237, 167, 219, 0.34);
  padding: 12rpx 24rpx;
  border-radius: 200rpx;
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

/* ============================================================
 *  下次上课(突出展示)
 * ============================================================ */
.section .card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 12rpx 32rpx rgba(181, 107, 162, 0.06);
  backdrop-filter: blur(14rpx);
}

/* 下次上课卡左侧粉色色条 */
.section:nth-of-type(1) .card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: var(--accent);
}

.section:nth-of-type(1) .card {
  padding-left: 34rpx;
}

.schedule-time {
  font-family: var(--font-num);
  font-size: 36rpx;
  color: var(--ink);
  display: block;
  letter-spacing: 0;
  line-height: 1.3;
  margin-bottom: 8rpx;
}

.schedule-classroom {
  font-family: var(--font-mono);
  font-size: 22rpx;
  color: var(--ink-soft);
  display: block;
  letter-spacing: 1rpx;
  margin-top: 8rpx;
}

/* ============================================================
 *  课时余额
 * ============================================================ */
.balance-card {
  padding: 28rpx 32rpx;
}

.balance-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid var(--line-soft);
  margin-bottom: 22rpx;
}

.balance-name {
  font-size: 30rpx;
  color: var(--ink);
  font-weight: 600;
  line-height: 1.35;
}

.balance-remain {
  font-family: var(--font-num);
  font-size: 44rpx;
  color: var(--ink);
  font-weight: 900;
  flex-shrink: 0;
}

.balance-remain.warning {
  color: var(--warn);
}

.balance-remain.danger {
  color: var(--red);
}

.balance-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.funds-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  background: rgba(255, 240, 250, 0.72);
  border: none;
  border-radius: 20rpx;
  padding: 18rpx 22rpx;
  margin-bottom: 20rpx;
}

.funds-label {
  font-size: 24rpx;
  color: var(--ink-soft);
  letter-spacing: 1rpx;
}

.funds-value {
  font-family: var(--font-num);
  font-size: 36rpx;
  color: var(--ink);
  font-weight: 900;
  line-height: 1.1;
  word-break: break-all;
  text-align: right;
}

.balance-cell {
  background: rgba(255, 240, 250, 0.66);
  border-radius: 20rpx;
  padding: 18rpx 12rpx;
  text-align: center;
}

.balance-num {
  display: block;
  font-family: var(--font-num);
  font-size: 30rpx;
  color: var(--ink);
  line-height: 1.2;
}

.balance-label {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: var(--ink-mute);
  letter-spacing: 1rpx;
}

.balance-empty {
  padding: 36rpx 24rpx;
}

/* ============================================================
 *  最新反馈卡
 * ============================================================ */
.feedback-date {
  font-family: var(--font-mono);
  font-size: 20rpx;
  color: var(--ink-mute);
  display: block;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.feedback-comment {
  font-family: var(--font-serif);
  font-size: 28rpx;
  color: var(--ink);
  display: block;
  line-height: 1.7;
  letter-spacing: 0rpx;
  position: relative;
  padding-left: 28rpx;
}

/* 左侧引号装饰 */
.feedback-comment::before {
  content: "";
  position: absolute;
  left: 0;
  top: 6rpx;
  bottom: 6rpx;
  width: 4rpx;
  background: var(--accent-soft);
  border-radius: 2rpx;
}

.audio-hint {
  display: inline-flex;
  align-items: center;
  margin-top: 24rpx;
  background: var(--accent-bg);
  color: var(--ink);
  border: none;
  padding: 10rpx 20rpx;
  border-radius: 200rpx;
  font-size: 22rpx;
  font-weight: 500;
}

/* ============================================================
 *  快捷操作
 * ============================================================ */
.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.action-item {
  background: rgba(255, 255, 255, 0.72);
  border: none;
  border-radius: 32rpx;
  padding: 32rpx 16rpx 28rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 12rpx 32rpx rgba(181, 107, 162, 0.06);
  backdrop-filter: blur(14rpx);
}

.action-item:nth-child(2) {
  transform: translateY(16rpx);
}

.action-item:active {
  background: var(--paper-warm);
}

.action-icon {
  width: 76rpx;
  height: 76rpx;
  background: linear-gradient(145deg, rgba(237, 167, 219, 0.9), rgba(255, 240, 250, 0.88));
  color: var(--ink);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  line-height: 1;
}

.action-text {
  font-size: 24rpx;
  font-weight: 850;
  color: var(--ink);
  letter-spacing: 1rpx;
}
