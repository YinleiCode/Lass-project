<view class="container">
  <view wx:if="{{loading}}" class="empty-state">正在整理请假课程...</view>

  <block wx:else>
    <view class="leave-hero">
      <text class="art-kicker">请假手记 · LEAVE NOTE</text>
      <text class="leave-title">为这一次缺席留个说明</text>
    </view>

    <view class="form">
      <view class="form-item">
        <text class="label">孩子</text>
        <text class="value-text">{{studentName || '未知'}}</text>
      </view>

      <view class="form-item">
        <text class="label">请假课程 *</text>
        <picker wx:if="{{hasSchedules}}" bindchange="onScheduleChange" range="{{schedules}}" range-key="labelText">
          <view class="picker">
            {{selectedScheduleIndex >= 0 ? schedules[selectedScheduleIndex].labelText : '选择即将上的课'}}
          </view>
        </picker>
        <view wx:else class="empty-course">暂无可请假的待上课程</view>
      </view>

      <view class="form-item">
        <text class="label">请假原因</text>
        <radio-group bindchange="onReasonChange">
          <label class="radio-label" wx:for="{{leaveReasons}}" wx:key="*this">
            <radio value="{{index}}" checked="{{index === selectedReasonIndex}}" /> {{item}}
          </label>
        </radio-group>
      </view>

      <view class="form-item">
        <text class="label">备注(选填)</text>
        <textarea class="textarea" placeholder="如有特殊情况请说明" value="{{notes}}" bindinput="onNotesInput" />
      </view>
    </view>

    <button class="btn-primary submit-btn" bindtap="onSubmit" loading="{{submitting}}" disabled="{{submitting || !hasSchedules}}">提交请假</button>
  </block>
</view>
