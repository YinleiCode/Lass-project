<view class="container">
  <view wx:if="{{loading}}" class="empty-state">正在翻开课后回声...</view>

  <view wx:elif="{{!feedback}}" class="empty-state">
    <empty-state icon="◇" text="暂无反馈内容" />
  </view>

  <view wx:else>
    <view class="feedback-detail-hero">
      <text class="art-kicker">课后回声 · FAMILY NOTE</text>
      <text class="detail-hero-title">老师留下的声音线索</text>
    </view>

    <!-- 课程信息 -->
    <view class="card" wx:if="{{scheduleInfo}}">
      <text class="info-date">{{scheduleDateText}}</text>
      <text class="info-pkg">{{packageNameText}}</text>
      <text class="info-meta" wx:if="{{scheduleMetaText}}">{{scheduleMetaText}}</text>
      <text class="info-meta" wx:if="{{scheduleTeacherText}}">{{scheduleTeacherText}}</text>
    </view>

    <!-- 维度评分 -->
    <view class="section">
      <view class="section-title">综合评分</view>
      <view class="card">
        <rating-stars
          wx:for="{{dimensions}}"
          wx:key="key"
          label="{{item.label}}"
          value="{{ratings[item.key] || 0}}"
          readonly="{{true}}"
        />
      </view>
    </view>

    <!-- 评语 -->
    <view class="section" wx:if="{{commentText}}">
      <view class="section-title">老师评语</view>
      <view class="card">
        <text class="comment-text">{{commentText}}</text>
      </view>
    </view>

    <!-- 录音 -->
    <view class="section" wx:if="{{hasAudio}}">
      <view class="section-title">语音回声</view>
      <view class="card">
        <audio-recorder
          wx:for="{{audioFiles}}"
          wx:key="*this"
          value="{{item}}"
          readonly="{{true}}"
        />
      </view>
    </view>
  </view>
</view>
