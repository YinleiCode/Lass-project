<view class="container">
  <view wx:if="{{loading}}" class="empty-state">正在整理孩子档案...</view>

  <view wx:elif="{{!student}}" class="empty-state">
    <empty-state icon="◇" text="未获取到学员信息" />
  </view>

  <view wx:else>
    <!-- 测试模式横幅 -->
    <view class="dev-banner" wx:if="{{switchedFromTeacher}}">
      <text class="dev-banner-icon">□</text>
      <text class="dev-banner-text">家长视角测试模式</text>
    </view>

    <!-- 学员信息 -->
    <view class="card">
      <view class="profile-header">
        <view class="avatar">{{avatarText}}</view>
        <view class="profile-info">
          <text class="profile-name">{{studentName}}</text>
          <text class="profile-phone" wx:if="{{maskedPhone}}">{{maskedPhone}}</text>
          <text class="profile-date" wx:if="{{enrollDateText}}">{{enrollDateText}}</text>
        </view>
      </view>
      <view class="tag-row" wx:if="{{student.tags && student.tags.length}}">
        <text class="tag" wx:for="{{student.tags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <!-- 设置项 -->
    <view class="settings-list">
      <view class="setting-item" bindtap="rebind" wx:if="{{!switchedFromTeacher}}">
        <text class="setting-label">重新绑定</text>
        <text class="setting-arrow">→</text>
      </view>
      <view class="setting-item dev-item" bindtap="onSwitchBackToTeacher" wx:if="{{switchedFromTeacher}}">
        <text class="setting-label">切回校长端</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>
</view>
<app-tab-bar />
