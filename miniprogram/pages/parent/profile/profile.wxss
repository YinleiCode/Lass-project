/* ============================================================
 *  parent/profile — 家长个人中心
 * ============================================================ */

/* === 个人信息卡(深色 ink 主题) === */
.container > .card:first-of-type {
  background: var(--ink);
  color: var(--paper);
  border: 1px solid var(--ink);
  border-radius: 20px;
  padding: 22px;
  position: relative;
  overflow: hidden;
  margin-bottom: 22px;
}

.container > .card:first-of-type::before {
  content: "";
  position: absolute;
  right: -30px;
  top: -30px;
  width: 140px;
  height: 140px;
  background: radial-gradient(circle, rgba(191, 209, 229, 0.18) 0%, transparent 70%);
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 16px;
  position: relative;
  z-index: 1;
}

.profile-header .avatar {
  width: 64px;
  height: 64px;
  border-radius: 20px;
  background: linear-gradient(135deg, var(--accent-mid), var(--accent));
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-serif);
  font-size: 26px;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 8px 20px -6px rgba(0, 0, 0, 0.35);
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-family: var(--font-serif);
  font-size: 22px;
  font-weight: 500;
  color: var(--paper);
  letter-spacing: 0.5px;
  display: block;
  margin-bottom: 6px;
}

.profile-phone {
  font-family: var(--font-mono);
  font-size: 12px;
  color: rgba(244, 247, 250, 0.7);
  letter-spacing: 0.5px;
  display: block;
}

.profile-date {
  font-family: var(--font-mono);
  font-size: 10px;
  color: rgba(244, 247, 250, 0.5);
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-top: 4px;
  display: block;
}

.container > .card:first-of-type .tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 14px;
  position: relative;
  z-index: 1;
}

.container > .card:first-of-type .tag {
  background: rgba(244, 247, 250, 0.12);
  color: var(--paper);
  border: none;
  padding: 3px 10px;
  border-radius: 100px;
  font-size: 11px;
  letter-spacing: 0.3px;
}

/* === 设置项列表 === */
.settings-list {
  background: var(--cream);
  border: 1px solid var(--line);
  border-radius: 16px;
  overflow: hidden;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 18px;
  border-bottom: 1px solid var(--line-soft);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  background: var(--paper-warm);
}

.setting-label {
  font-size: 14px;
  color: var(--ink);
  font-weight: 500;
  letter-spacing: 0.5px;
}

.setting-arrow {
  font-family: var(--font-mono);
  color: var(--ink-mute);
  font-size: 16px;
}
