/* ============================================================
 *  parent/profile — 家长个人中心
 * ============================================================ */

/* === 个人信息卡 === */
.container > .card:first-of-type {
  background:
    radial-gradient(circle at 86% 0%, rgba(237, 167, 219, 0.44) 0, transparent 230rpx),
    radial-gradient(circle at 8% 100%, rgba(255, 255, 255, 0.72) 0, transparent 260rpx),
    linear-gradient(145deg, rgba(255, 246, 252, 0.92), rgba(246, 235, 242, 0.82));
  color: var(--ink);
  border: none;
  border-radius: 40rpx;
  padding: 32rpx;
  position: relative;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.76), 0 18rpx 44rpx rgba(108, 45, 88, 0.07);
  backdrop-filter: blur(16rpx);
}

.container > .card:first-of-type::before {
  content: "";
  position: absolute;
  right: -60rpx;
  top: -60rpx;
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle, rgba(237, 167, 219, 0.42) 0%, transparent 70%);
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.profile-header .avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--accent);
  color: var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-sans);
  font-size: 40rpx;
  font-weight: 900;
  flex-shrink: 0;
  box-shadow: 0 10rpx 24rpx -10rpx rgba(108, 45, 88, 0.36);
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-family: var(--font-sans);
  font-size: 34rpx;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: 1rpx;
  display: block;
  margin-bottom: 10rpx;
}

.profile-phone {
  font-family: var(--font-mono);
  font-size: 24rpx;
  color: var(--ink-soft);
  letter-spacing: 1rpx;
  display: block;
}

.profile-date {
  font-family: var(--font-mono);
  font-size: 20rpx;
  color: var(--ink-mute);
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-top: 8rpx;
  display: block;
}

.container > .card:first-of-type .tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
  position: relative;
  z-index: 1;
}

.container > .card:first-of-type .tag {
  background: rgba(255, 255, 255, 0.68);
  color: var(--ink);
  border: none;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

/* === 设置项列表 === */
.settings-list {
  background: rgba(255, 255, 255, 0.72);
  border: none;
  border-radius: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(181, 107, 162, 0.06);
  overflow: hidden;
  backdrop-filter: blur(14rpx);
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid var(--line-soft);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  background: var(--paper-warm);
}

.setting-label {
  font-size: 28rpx;
  color: var(--ink);
  font-weight: 850;
  letter-spacing: 1rpx;
}

.setting-arrow {
  font-family: var(--font-mono);
  color: var(--ink-mute);
  font-size: 32rpx;
}

/* === 开发者工具:切回老师视角 === */
.setting-item.dev-item {
  background:
    radial-gradient(circle at 86% 10%, rgba(237, 167, 219, 0.30) 0, transparent 170rpx),
    rgba(255, 255, 255, 0.72);
}

.setting-item.dev-item .setting-label {
  color: var(--ink);
}

.setting-item.dev-item .setting-arrow {
  color: var(--ink-mute);
}

/* 测试模式横幅 */
.dev-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background:
    radial-gradient(circle at 12% 18%, rgba(255, 255, 255, 0.82) 0, transparent 140rpx),
    linear-gradient(145deg, rgba(255, 246, 252, 0.88), rgba(247, 238, 244, 0.72));
  border: none;
  border-radius: 30rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.68), 0 12rpx 30rpx rgba(181, 107, 162, 0.06);
  backdrop-filter: blur(14rpx);
}

.dev-banner-icon {
  font-size: 32rpx;
}

.dev-banner-text {
  font-size: 24rpx;
  color: var(--ink-soft);
  letter-spacing: 1rpx;
  font-weight: 800;
}
