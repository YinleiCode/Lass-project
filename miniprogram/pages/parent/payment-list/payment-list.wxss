.summary-card {
  background: #4A90D9;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.summary-row {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  text-align: center;
}

.summary-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.summary-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-top: 8rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.order-date {
  font-size: 26rpx;
  color: #666;
}

.order-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #F44336;
}

.order-body {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.order-count {
  font-size: 28rpx;
  color: #4A90D9;
  font-weight: bold;
}

.order-pkg {
  font-size: 24rpx;
  color: #999;
}

.order-method {
  font-size: 22rpx;
  color: #BBB;
  display: block;
}
