/* ============================================================
 *  parent/payment-list — 缴费记录
 * ============================================================ */

/* === 累计统计卡(深色) === */
.summary-card {
  background: var(--ink);
  color: var(--paper);
  border-radius: 20px;
  padding: 22px;
  margin-bottom: 22px;
  position: relative;
  overflow: hidden;
}

.summary-card::before {
  content: "";
  position: absolute;
  right: -30px;
  top: -30px;
  width: 140px;
  height: 140px;
  background: radial-gradient(circle, rgba(191, 209, 229, 0.16) 0%, transparent 70%);
  pointer-events: none;
}

.summary-row {
  display: flex;
  gap: 22px;
  position: relative;
  z-index: 1;
}

.summary-item {
  flex: 1;
  text-align: left;
}

.summary-item:not(:last-child) {
  padding-right: 22px;
  border-right: 1px solid rgba(244, 247, 250, 0.12);
}

.summary-value {
  display: block;
  font-family: var(--font-num);
  font-size: 32px;
  color: var(--paper);
  letter-spacing: -1px;
  line-height: 1;
  margin-bottom: 8px;
}

.summary-label {
  display: block;
  font-family: var(--font-mono);
  font-size: 10px;
  color: rgba(244, 247, 250, 0.55);
  letter-spacing: 1.5px;
  text-transform: uppercase;
}

/* === 缴费列表卡 === */
.container > .card {
  background: var(--cream);
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 14px 16px;
  margin-bottom: 10px;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8px;
  padding-bottom: 8px;
  border-bottom: 1px dashed var(--line-soft);
}

.order-date {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-mute);
  letter-spacing: 1px;
  text-transform: uppercase;
}

.order-amount {
  font-family: var(--font-num);
  font-size: 22px;
  color: var(--accent);
  letter-spacing: -0.5px;
}

.order-body {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 6px;
}

.order-count {
  background: var(--accent-bg);
  color: var(--accent);
  border: 1px solid var(--accent-soft);
  padding: 3px 9px;
  border-radius: 100px;
  font-size: 11px;
  font-weight: 500;
}

.order-pkg {
  font-size: 13px;
  color: var(--ink);
  letter-spacing: 0.3px;
}

.order-method {
  display: block;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-mute);
  letter-spacing: 0.5px;
}
