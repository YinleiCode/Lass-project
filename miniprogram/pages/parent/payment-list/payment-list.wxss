/* ============================================================
 *  parent/payment-list — 缴费记录
 * ============================================================ */

/* === 累计统计卡 === */
.summary-card {
  background:
    radial-gradient(circle at 86% 0%, rgba(237, 167, 219, 0.44) 0, transparent 230rpx),
    radial-gradient(circle at 8% 100%, rgba(255, 255, 255, 0.72) 0, transparent 260rpx),
    linear-gradient(145deg, rgba(255, 246, 252, 0.92), rgba(246, 235, 242, 0.82));
  color: var(--ink);
  border-radius: 36rpx;
  padding: 36rpx;
  margin-bottom: 32rpx;
  position: relative;
  overflow: hidden;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.76), 0 18rpx 44rpx rgba(108, 45, 88, 0.07);
  backdrop-filter: blur(16rpx);
}

.summary-card::before {
  content: "";
  position: absolute;
  right: -60rpx;
  top: -60rpx;
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle, rgba(237, 167, 219, 0.42) 0%, transparent 70%);
  pointer-events: none;
}

.summary-row {
  display: flex;
  gap: 32rpx;
  position: relative;
  z-index: 1;
}

.summary-item {
  flex: 1;
  text-align: left;
}

.summary-item:not(:last-child) {
  padding-right: 32rpx;
  border-right: 2rpx solid rgba(108, 45, 88, 0.08);
}

.summary-value {
  display: block;
  font-family: var(--font-num);
  font-size: 64rpx;
  color: var(--ink);
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1;
  margin-bottom: 12rpx;
}

.summary-label {
  display: block;
  font-family: var(--font-mono);
  font-size: 22rpx;
  color: var(--ink-mute);
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

/* === 缴费列表卡 === */
.container > .card {
  background: var(--cream);
  border: none;
  border-radius: 32rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx dashed var(--line-soft);
}

.order-date {
  font-family: var(--font-mono);
  font-size: 22rpx;
  color: var(--ink-mute);
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.order-amount {
  font-family: var(--font-num);
  font-size: 44rpx;
  color: var(--ink);
  font-weight: 900;
  letter-spacing: 0;
}

.order-body {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.order-count {
  background: var(--accent-bg);
  color: var(--ink);
  border: none;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.order-pkg {
  font-size: 26rpx;
  color: var(--ink);
  letter-spacing: 1rpx;
}

.order-method {
  display: block;
  font-family: var(--font-mono);
  font-size: 22rpx;
  color: var(--ink-mute);
  letter-spacing: 1rpx;
}
