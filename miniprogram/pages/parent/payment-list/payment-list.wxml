<view class="container">
  <view wx:if="{{loading}}" class="empty-state">正在整理课程记录...</view>

  <block wx:else>
    <block wx:if="{{teacherMode}}">
      <view class="summary-card">
        <view class="summary-row">
          <view class="summary-item">
            <text class="summary-value">{{totalAmountText}}</text>
            <text class="summary-label">累计缴费</text>
          </view>
          <view class="summary-item">
            <text class="summary-value">{{totalCourseCount}}</text>
            <text class="summary-label">累计课时</text>
          </view>
        </view>
      </view>

      <view wx:if="{{!hasOrders}}" class="empty-state">
        <empty-state icon="◇" text="暂无缴费记录" />
      </view>

      <view wx:else>
        <view class="card" wx:for="{{orders}}" wx:key="_id">
          <view class="order-header">
            <text class="order-date">{{item.payDateText}}</text>
            <text class="order-amount">{{item.amountText}}</text>
          </view>
          <view class="order-body">
            <text class="order-count">{{item.courseCountText}}</text>
            <text class="order-pkg">{{item.packageNameText}}</text>
          </view>
          <text class="order-method">{{item.payMethodText}}</text>
        </view>
      </view>
    </block>

    <view wx:else class="empty-state">
      <empty-state icon="◇" text="当前账号不能查看此页面" />
    </view>
  </block>
</view>
