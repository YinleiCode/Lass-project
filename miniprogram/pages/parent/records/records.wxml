<view class="container">
  <view class="records-hero">
    <text class="art-kicker">反馈集 · VOICE ARCHIVE</text>
    <text class="records-title">{{pageTitle}}</text>
  </view>

  <view class="filter-bar">
    <view class="filter-item {{filter === 'all' ? 'active' : ''}}" data-filter="all" bindtap="setFilter">全部</view>
    <view class="filter-item {{filter === 'thisMonth' ? 'active' : ''}}" data-filter="thisMonth" bindtap="setFilter">本月</view>
    <view class="filter-item {{filter === 'lastMonth' ? 'active' : ''}}" data-filter="lastMonth" bindtap="setFilter">上月</view>
  </view>

  <view wx:if="{{loading}}" class="empty-state">正在整理反馈集...</view>

  <view wx:elif="{{filteredFeedbacks.length === 0}}" class="empty-state">
    <empty-state icon="◇" text="暂无上课记录" />
  </view>

  <view wx:else>
    <view
      class="record-item"
      wx:for="{{filteredFeedbacks}}"
      wx:key="_id"
      data-scheduleid="{{item.schedule_id}}"
      data-studentid="{{item.student_id}}"
      bindtap="goFeedbackDetail"
    >
      <view class="record-dot"></view>
      <view class="record-content">
        <text class="record-date">{{item.dateText}}</text>
        <text class="record-title">{{item.titleText}}</text>
        <text class="record-comment">{{item.commentPreview}}</text>
        <view class="record-tags">
          <text class="tag" wx:if="{{item.scoreText}}">{{item.scoreText}}</text>
          <text class="tag" wx:if="{{item.audioText}}">{{item.audioText}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
<app-tab-bar />
