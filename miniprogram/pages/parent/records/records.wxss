/* ============================================================
 *  parent/records — 上课记录(反馈列表)
 * ============================================================ */

/* === 筛选 Tabs === */
.filter-bar {
  display: flex;
  background: var(--cream);
  border: 1px solid var(--line);
  border-radius: 100px;
  padding: 4px;
  margin-bottom: 18px;
  gap: 4px;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 8px 0;
  font-size: 12px;
  font-weight: 500;
  color: var(--ink-soft);
  border-radius: 100px;
  letter-spacing: 0.5px;
  transition: all 0.15s;
}

.filter-item.active {
  background: var(--ink);
  color: var(--paper);
}

/* === 时间线列表 === */
.record-item {
  display: flex;
  gap: 14px;
  padding: 16px 0;
  position: relative;
}

/* 时间轴竖线 */
.record-item::before {
  content: "";
  position: absolute;
  left: 5px;
  top: 32px;
  bottom: -16px;
  width: 1px;
  background: var(--line);
}

.record-item:last-child::before {
  display: none;
}

.record-dot {
  width: 11px;
  height: 11px;
  border-radius: 50%;
  background: var(--cream);
  border: 2.5px solid var(--accent);
  flex-shrink: 0;
  margin-top: 5px;
  position: relative;
  z-index: 1;
  box-shadow: 0 0 0 4px rgba(44, 82, 130, 0.08);
}

.record-dot.green {
  border-color: var(--green);
  box-shadow: 0 0 0 4px rgba(77, 124, 15, 0.12);
}

.record-content {
  flex: 1;
  background: var(--cream);
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 14px 16px;
  min-width: 0;
}

.record-content:active {
  background: var(--paper-warm);
}

.record-date {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-mute);
  letter-spacing: 1px;
  text-transform: uppercase;
  display: block;
  margin-bottom: 8px;
}

.record-comment {
  display: block;
  font-family: var(--font-serif);
  font-size: 14px;
  color: var(--ink);
  line-height: 1.6;
  letter-spacing: 0.3px;
  margin-bottom: 10px;
}

.record-tags {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.record-tags .tag {
  background: var(--accent-bg);
  color: var(--accent);
  border: 1px solid var(--accent-soft);
  padding: 3px 9px;
  border-radius: 100px;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.3px;
}
