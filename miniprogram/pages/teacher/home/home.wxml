<view class="container">
  <!-- Loading -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="stats-grid">
      <view class="stat-card skeleton" wx:for="{{4}}" wx:key="*this"><view class="value">--</view><view class="label">整理中</view></view>
    </view>
  </view>

  <block wx:else>
    <!-- 粉黑首屏 -->
    <view class="teacher-hero">
      <view class="hero-copy">
        <text class="art-kicker hero-kicker">声场手账 · DAILY SCORE</text>
        <view class="hero-top">
          <view class="greeting">
            <text class="greeting-text">今日</text>
            <text class="greeting-text">课时</text>
          </view>
          <view class="hero-bell">♬</view>
        </view>
      </view>
      <image class="hero-illustration" src="/images/hero-teacher-mist.png" mode="aspectFit"></image>
      <view class="today-total" wx:if="{{stats}}">
        <text class="today-total-main">今天共 {{stats.todayLessonCount || 0}} 节</text>
        <text class="today-total-sub">{{stats.todayTotalMinutesText || '0分钟'}}</text>
      </view>
      <view class="hero-search" bindtap="goStudents">
        <text class="search-icon">⌕</text>
        <text class="search-placeholder">查找学员 / 课次 / 回声</text>
      </view>
      <text class="art-note hero-note">把今天的课时、点名和课后回声，安静收进手账。</text>
    </view>

    <!-- 首次引导:无课程包(最高优先级) -->
    <view class="guide-banner" wx:if="{{showPackagesGuide}}">
      <view class="guide-content">
        <text class="guide-icon">□</text>
        <view class="guide-text-wrap">
          <text class="guide-title">先创建课程包</text>
          <text class="guide-desc">{{isAdmin ? '缴费、排课都需要先有课程包' : '课程包由管理员配置后才能排课'}}</text>
        </view>
        <button class="guide-cta" bindtap="goAddPackage">{{isAdmin ? '去创建' : '联系管理员'}}</button>
      </view>
      <text class="guide-dismiss" data-type="packages" catchtap="dismissGuide">✕</text>
    </view>

    <!-- 首次引导:无学员 -->
    <view class="guide-banner" wx:elif="{{showStudentsGuide}}">
      <view class="guide-content">
        <text class="guide-icon">◎</text>
        <view class="guide-text-wrap">
          <text class="guide-title">添加第一位学员</text>
          <text class="guide-desc">从学员开始建立你的工作室</text>
        </view>
        <button class="guide-cta" bindtap="goAddStudent">去添加</button>
      </view>
      <text class="guide-dismiss" data-type="students" catchtap="dismissGuide">✕</text>
    </view>

    <!-- 首次引导:无排课 -->
    <view class="guide-banner" wx:elif="{{showSchedulesGuide}}">
      <view class="guide-content">
        <text class="guide-icon">◷</text>
        <view class="guide-text-wrap">
          <text class="guide-title">安排第一节课</text>
          <text class="guide-desc">为学员排课,开始上课流程</text>
        </view>
        <button class="guide-cta" bindtap="goAddSchedule">去排课</button>
      </view>
      <text class="guide-dismiss" data-type="schedules" catchtap="dismissGuide">✕</text>
    </view>

    <!-- 数据概览卡片 -->
    <view class="home-feature-grid" wx:if="{{stats}}">
      <view class="feature-tile" bindtap="goCalendar">
        <text class="tile-index">01</text>
        <text class="feature-title">今日</text>
        <text class="feature-title">课时</text>
        <view class="feature-bottom">
          <text class="feature-pill">{{stats.todayPending || 0}} 节待上</text>
          <text class="feature-play">›</text>
        </view>
      </view>
      <view class="feature-tile pink" bindtap="goStudents">
        <text class="tile-index">02</text>
        <text class="feature-title">余课</text>
        <text class="feature-title">提醒</text>
        <view class="feature-bottom">
          <text class="feature-pill">{{stats.warningCount || 0}} 位关注</text>
          <text class="feature-play">›</text>
        </view>
      </view>
      <view class="feature-tile slim" bindtap="goCalendar">
        <text class="feature-num">{{stats.monthAttendance || 0}}</text>
        <text class="feature-label">本月课消</text>
      </view>
      <view class="feature-tile slim" wx:if="{{isAdmin}}" bindtap="goCalendar">
        <text class="feature-num money">{{stats.monthIncome_str || '¥0'}}</text>
        <text class="feature-label">本月收入</text>
      </view>
      <view class="feature-tile slim" wx:else bindtap="goCalendar">
        <text class="feature-num">{{stats.todayTotalMinutes || 0}}</text>
        <text class="feature-label">今日分钟</text>
      </view>
    </view>

    <!-- 今日课表 -->
    <view class="practice-panel">
      <view class="practice-handle"></view>
      <view class="practice-head" bindtap="goCalendar" hover-class="tap-muted">
        <view>
          <text class="practice-title">今日排课</text>
          <text class="practice-sub">VOICE ROOM · DAILY SCHEDULE</text>
        </view>
        <text class="practice-more" catchtap="goCalendar">全览 ›</text>
      </view>

      <view wx:if="{{todaySchedules.length === 0}}" class="practice-empty">
        <text class="empty-text">今天留白，让声音慢慢沉淀。</text>
      </view>

      <view class="practice-list" wx:else>
        <view class="practice-card" wx:for="{{todaySchedules}}" wx:key="_id">
          <view class="practice-info">
            <text class="practice-name">{{item.time_str || '--:--'}} {{item.student_names || '课程'}}</text>
            <view class="practice-meta-row">
              <text class="practice-time">{{item.class_display || item.class_type_label || '课程'}}</text>
              <text class="practice-meta" wx:if="{{item.duration_text}}">{{item.duration_text}}</text>
              <text class="practice-meta">授课老师：{{item.teacher_name || '授课老师'}}</text>
              <text class="practice-meta">{{item.delivery_mode_label || '线下课'}}</text>
              <text class="tag tag-warning" wx:if="{{item.has_leave}}">{{item.leave_label}}</text>
            </view>
          </view>
          <view class="schedule-action" wx:if="{{item.status === 'pending'}}">
            <view class="practice-action-pill" data-id="{{item._id}}" bindtap="goCheckin">
              <text>点名</text>
              <text class="practice-action-arrow">›</text>
            </view>
          </view>
          <view class="schedule-status" wx:else data-id="{{item._id}}" bindtap="goFeedback">
            <view class="practice-action-pill done">
              <text>反馈</text>
              <text class="practice-action-arrow">›</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 课时预警 -->
    <view class="section">
      <view class="section-title">
        <text>余课提醒</text>
        <text class="more" bindtap="goStudents">学员册 ›</text>
      </view>

      <view wx:if="{{warningList.length === 0}}" class="empty-state">
        <text class="empty-text">课时像呼吸一样平稳。</text>
      </view>

      <view wx:else>
        <view class="list-item" wx:for="{{warningList}}" wx:key="_id" data-id="{{item._id}}" bindtap="goStudentDetail">
          <text class="student-warning-name">{{item.name}}</text>
          <text class="tag tag-danger">剩余 {{item.remaining}} 节</text>
        </view>
      </view>
    </view>
  </block>
</view>
