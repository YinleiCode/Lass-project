/* ============================================================
 *  teacher/home — 老师端首页
 *  设计系统 V2.0 粉黑线描
 * ============================================================ */

/* === 首次引导横幅 === */
.guide-banner {
  background: var(--accent-bg);
  border: none;
  border-radius: 34rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 44rpx;
  position: relative;
  overflow: hidden;
}

.guide-banner::before {
  content: "";
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(34, 0, 22, 0.08) 0%, transparent 70%);
  pointer-events: none;
}

.guide-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.guide-icon {
  font-size: 56rpx;
  line-height: 1;
  flex-shrink: 0;
}

.guide-text-wrap {
  flex: 1;
  min-width: 0;
}

.guide-title {
  display: block;
  font-family: var(--font-serif);
  font-size: 32rpx;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: 1rpx;
  margin-bottom: 4rpx;
}

.guide-desc {
  display: block;
  font-size: 22rpx;
  color: var(--ink-soft);
  font-family: var(--font-mono);
  letter-spacing: 1rpx;
}

.guide-cta {
  background: linear-gradient(145deg, rgba(237, 167, 219, 0.84), rgba(255, 240, 250, 0.92));
  color: var(--ink);
  border: none;
  padding: 16rpx 32rpx;
  border-radius: 200rpx;
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  line-height: 1.4;
  flex-shrink: 0;
}

.guide-cta::after {
  border: none;
}

.guide-dismiss {
  position: absolute;
  right: 16rpx;
  top: 16rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--ink-mute);
  z-index: 2;
}

/* === 问候区 === */
.greeting {
  padding: 8rpx 0 28rpx;
}

.greeting-text {
  font-family: var(--font-serif);
  font-size: 68rpx;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: 0;
  line-height: 0.98;
  display: block;
}

/* === V2 首屏: 大标题 + 插画 + 搜索 === */
.teacher-hero {
  position: relative;
  min-height: 508rpx;
  margin: 0 0 26rpx;
  padding: 34rpx 30rpx 28rpx;
  border-radius: 44rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 76% 18%, rgba(237, 167, 219, 0.58) 0, transparent 210rpx),
    radial-gradient(circle at 18% 86%, rgba(255, 255, 255, 0.95) 0, transparent 250rpx),
    linear-gradient(145deg, rgba(255, 240, 250, 0.92), rgba(251, 248, 247, 0.84));
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.78), 0 20rpx 52rpx rgba(181, 107, 162, 0.08);
}

.hero-kicker {
  margin: 0 0 20rpx;
  padding-left: 4rpx;
}

.hero-copy {
  position: relative;
  z-index: 2;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
}

.teacher-hero::before {
  content: "";
  position: absolute;
  right: 52rpx;
  top: 52rpx;
  width: 176rpx;
  height: 176rpx;
  border: 2rpx solid rgba(108, 45, 88, 0.08);
  border-radius: 50%;
}

.teacher-hero::after {
  content: "";
  position: absolute;
  left: -120rpx;
  bottom: -160rpx;
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  background: rgba(237, 167, 219, 0.16);
  filter: blur(2rpx);
}

.hero-bell {
  width: 82rpx;
  height: 82rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.66);
  color: var(--plum);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  box-shadow: inset 0 0 0 2rpx rgba(108, 45, 88, 0.09), 0 12rpx 26rpx rgba(181, 107, 162, 0.14);
  flex-shrink: 0;
  backdrop-filter: blur(16rpx);
}

.hero-search {
  height: 84rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.74);
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 28rpx;
  margin: 10rpx 0 18rpx;
  box-shadow: inset 0 0 0 2rpx rgba(108, 45, 88, 0.04), 0 14rpx 32rpx rgba(181, 107, 162, 0.09);
  position: relative;
  z-index: 3;
  backdrop-filter: blur(16rpx);
}

.today-total {
  position: relative;
  z-index: 3;
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: -2rpx 8rpx 18rpx;
  flex-wrap: wrap;
}

.today-total-main,
.today-total-sub {
  min-height: 54rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.74);
  color: var(--ink);
  font-size: 23rpx;
  font-weight: 900;
  display: inline-flex;
  align-items: center;
  box-shadow: inset 0 0 0 2rpx rgba(108, 45, 88, 0.05);
}

.today-total-sub {
  background: rgba(237, 167, 219, 0.34);
  color: var(--ink-soft);
}

.search-icon {
  font-size: 34rpx;
  color: var(--ink-soft);
}

.search-placeholder {
  color: var(--ink-mute);
  font-size: 25rpx;
  letter-spacing: 0.5rpx;
}

.hero-illustration {
  width: 480rpx;
  height: 270rpx;
  display: block;
  position: relative;
  z-index: 2;
  margin: -46rpx -12rpx -6rpx auto;
  border-radius: 0;
  overflow: hidden;
  background: transparent;
  box-shadow: none;
}

.hero-note {
  margin: 0 8rpx 0;
  max-width: 520rpx;
  position: relative;
  z-index: 3;
}

.home-feature-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.feature-tile {
  position: relative;
  min-height: 184rpx;
  background: #F1EFF1;
  border-radius: 32rpx;
  padding: 26rpx 24rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 34rpx rgba(34, 0, 22, 0.045);
}

.feature-tile::before {
  content: "";
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  top: 22rpx;
  height: 2rpx;
  background: rgba(34, 0, 22, 0.06);
}

.feature-tile::after {
  content: "";
  position: absolute;
  right: -32rpx;
  top: -32rpx;
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background: rgba(237, 167, 219, 0.18);
}

.tile-index {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  color: rgba(34, 0, 22, 0.22);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.feature-tile.pink {
  background: var(--accent-bg);
}

.feature-tile.slim {
  min-height: 184rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.feature-tile.slim:nth-child(3) {
}

.feature-tile.slim:nth-child(4) {
}

.feature-title {
  white-space: pre-line;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.02;
  letter-spacing: 0;
  color: var(--ink);
}

.feature-bottom {
  position: absolute;
  left: 24rpx;
  right: 20rpx;
  bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.feature-pill {
  min-height: 50rpx;
  border-radius: 999rpx;
  background: white;
  padding: 0 22rpx;
  display: inline-flex;
  align-items: center;
  color: var(--ink);
  font-size: 22rpx;
  font-weight: 850;
}

.feature-play,
.practice-action {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--accent);
  color: var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.feature-num {
  font-size: 52rpx;
  line-height: 1;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: 0;
}

.feature-num.money {
  font-size: 38rpx;
  word-break: break-all;
}

.feature-label {
  margin-top: 10rpx;
  color: var(--ink-mute);
  font-size: 22rpx;
  font-weight: 700;
}

.practice-panel {
  background:
    radial-gradient(circle at 85% 0%, rgba(237, 167, 219, 0.42) 0, transparent 240rpx),
    radial-gradient(circle at 10% 96%, rgba(255, 255, 255, 0.72) 0, transparent 260rpx),
    linear-gradient(145deg, rgba(255, 246, 252, 0.90), rgba(246, 235, 242, 0.82));
  color: var(--ink);
  border-radius: 44rpx 44rpx 34rpx 34rpx;
  padding: 26rpx 22rpx 24rpx;
  margin: 10rpx -2rpx 36rpx;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.72), 0 18rpx 44rpx rgba(108, 45, 88, 0.07);
  position: relative;
  overflow: hidden;
}

.practice-panel::before {
  content: "";
  position: absolute;
  right: -180rpx;
  top: -140rpx;
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.50);
  pointer-events: none;
}

.practice-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(108, 45, 88, 0.12);
  margin: -12rpx auto 22rpx;
}

.practice-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 0 18rpx 8rpx;
  min-height: 74rpx;
  position: relative;
  z-index: 3;
  box-sizing: border-box;
}

.practice-title {
  display: block;
  font-size: 36rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.practice-sub {
  display: block;
  margin-top: 4rpx;
  color: var(--ink-mute);
  font-size: 17rpx;
  font-weight: 850;
  letter-spacing: 2.6rpx;
}

.practice-more {
  min-height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: var(--ink);
  font-size: 24rpx;
  font-weight: 850;
  display: inline-flex;
  align-items: center;
  box-shadow: inset 0 0 0 2rpx rgba(108, 45, 88, 0.06), 0 10rpx 24rpx rgba(181, 107, 162, 0.08);
}

.practice-card,
.practice-empty {
  background: rgba(255, 255, 255, 0.72);
  color: var(--ink);
  border-radius: 30rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.practice-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.practice-info {
  flex: 1;
  min-width: 0;
}

.practice-name {
  font-size: 29rpx;
  font-weight: 900;
  color: var(--ink);
  display: block;
  margin-bottom: 14rpx;
  line-height: 1.3;
  word-break: break-all;
}

.practice-meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.practice-time {
  background: rgba(237, 167, 219, 0.36);
  color: var(--ink);
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-size: 22rpx;
  font-weight: 850;
}

.practice-meta {
  color: var(--ink-soft);
  font-size: 22rpx;
}

.practice-action-pill {
  min-width: 150rpx;
  height: 58rpx;
  padding: 0 10rpx 0 24rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  color: var(--ink);
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
  letter-spacing: 1rpx;
  background:
    radial-gradient(circle at 26% 22%, rgba(255, 255, 255, 0.84), transparent 52%),
    linear-gradient(145deg, rgba(237, 167, 219, 0.84), rgba(255, 238, 250, 0.90));
  box-shadow: inset 0 0 0 2rpx rgba(108, 45, 88, 0.055), 0 10rpx 24rpx rgba(181, 107, 162, 0.10);
  box-sizing: border-box;
}

.practice-action-pill.done {
  background: rgba(255, 255, 255, 0.76);
  color: var(--ink);
}

.practice-action-arrow {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.76);
  color: var(--plum);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

/* === 区段 === */
.section {
  margin-bottom: 40rpx;
}

/* === 数据卡片 - 第 4 个卡(预警)特殊样式 === */
.stats-grid .stat-card {
  background: #F1EFF1;
  border: none;
  box-shadow: var(--shadow-sm);
  min-height: 176rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.stats-grid .stat-card .value {
  color: var(--ink);
  font-size: 62rpx;
  font-weight: 900;
  line-height: 0.95;
}

.stats-grid .stat-card .label {
  color: var(--ink-soft);
  margin-top: 10rpx;
  font-size: 22rpx;
}

.stat-card .value.danger {
  color: var(--warn);
}

/* === 今日课表列表 === */
.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.schedule-list .list-item {
  background: var(--cream);
  border: none;
  border-radius: 28rpx;
  padding: 24rpx 26rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-bottom: 0;
  box-shadow: var(--shadow-sm);
}

.schedule-time {
  font-family: var(--font-num);
  font-size: 38rpx;
  color: var(--ink);
  min-width: 112rpx;
  flex-shrink: 0;
  line-height: 1;
  letter-spacing: 0;
  position: relative;
}

/* 时间右侧细分割线 */
.schedule-time::after {
  content: "";
  position: absolute;
  right: -12rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 2rpx;
  height: 44rpx;
  background: var(--accent-soft);
}

.schedule-info {
  flex: 1;
  min-width: 0;
  padding-left: 12rpx;
}

.schedule-name {
  font-size: 28rpx;
  font-weight: 850;
  color: var(--ink);
  display: block;
  margin-bottom: 6rpx;
  letter-spacing: 1rpx;
}

.schedule-meta {
  font-size: 22rpx;
  color: var(--ink-soft);
  display: block;
  font-family: var(--font-mono);
  letter-spacing: 1rpx;
}

.schedule-action {
  flex-shrink: 0;
}

.schedule-action .btn-primary.small {
  background: linear-gradient(145deg, rgba(237, 167, 219, 0.84), rgba(255, 240, 250, 0.92));
  color: var(--ink);
  border: none;
  min-height: 64rpx;
  padding: 0 28rpx;
  border-radius: 200rpx;
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  line-height: 1.4;
  display: inline-block;
}

.schedule-status .tag-success {
  background: transparent;
  color: var(--ink-mute);
  border: 2rpx solid var(--line);
  padding: 10rpx 20rpx;
  border-radius: 200rpx;
  font-size: 22rpx;
}

.schedule-status .tag-success::before {
  content: "✓ ";
  color: var(--green);
}

/* === 课时预警区 === */
.section:last-of-type .list-item {
  background: var(--warn-bg);
  border: none;
  border-radius: 30rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.student-warning-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--warn-text);
  font-family: var(--font-sans);
  letter-spacing: 1rpx;
}

.section:last-of-type .tag-danger {
  background: rgba(255, 255, 255, 0.7);
  border: 2rpx solid var(--warn-border);
  color: var(--warn-text);
  padding: 8rpx 20rpx;
  border-radius: 200rpx;
  font-size: 22rpx;
  font-weight: 500;
}

/* === 骨架屏 === */
.loading-state .stat-card {
  background: var(--paper-warm);
  border-color: var(--line-soft);
}

.loading-state .stat-card.skeleton .value {
  color: var(--ink-mute);
  font-family: var(--font-num);
}

.loading-state .stat-card.skeleton .label {
  color: var(--ink-mute);
}

.skeleton {
  opacity: 0.6;
}

/* === 空状态(覆盖默认在卡片内的处理) === */
.section .empty-state {
  background: var(--cream);
  border: none;
  border-radius: 30rpx;
  padding: 64rpx 44rpx;
}

.section .empty-text {
  font-size: 26rpx;
  color: var(--ink-soft);
  font-family: var(--font-sans);
}
