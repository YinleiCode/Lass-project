/* ============================================================
 *  teacher/home — 老师端首页
 *  设计系统 V1.0
 * ============================================================ */

/* === 首次引导横幅 === */
.guide-banner {
  background: linear-gradient(135deg, var(--accent-bg) 0%, #DCE9F5 100%);
  border: 1px dashed var(--accent-soft);
  border-radius: 16px;
  padding: 14px 16px;
  margin-bottom: 22px;
  position: relative;
  overflow: hidden;
}

.guide-banner::before {
  content: "";
  position: absolute;
  right: -20px;
  top: -20px;
  width: 100px;
  height: 100px;
  background: radial-gradient(circle, rgba(44, 82, 130, 0.08) 0%, transparent 70%);
  pointer-events: none;
}

.guide-content {
  display: flex;
  align-items: center;
  gap: 12px;
  position: relative;
  z-index: 1;
}

.guide-icon {
  font-size: 28px;
  line-height: 1;
  flex-shrink: 0;
}

.guide-text-wrap {
  flex: 1;
  min-width: 0;
}

.guide-title {
  display: block;
  font-family: var(--font-serif);
  font-size: 15px;
  font-weight: 600;
  color: var(--ink);
  letter-spacing: 0.5px;
  margin-bottom: 2px;
}

.guide-desc {
  display: block;
  font-size: 11px;
  color: var(--ink-soft);
  font-family: var(--font-mono);
  letter-spacing: 0.3px;
}

.guide-cta {
  background: var(--accent);
  color: white;
  border: none;
  padding: 8px 16px;
  border-radius: 100px;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.5px;
  line-height: 1.4;
  flex-shrink: 0;
}

.guide-cta::after {
  border: none;
}

.guide-dismiss {
  position: absolute;
  right: 8px;
  top: 8px;
  width: 22px;
  height: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  color: var(--ink-mute);
  z-index: 2;
}

/* === 问候区 === */
.greeting {
  padding: 8px 0 22px;
}

.greeting-text {
  font-family: var(--font-serif);
  font-size: 28px;
  font-weight: 500;
  color: var(--ink);
  letter-spacing: -0.5px;
  line-height: 1.3;
  display: block;
}

/* === 区段 === */
.section {
  margin-bottom: 28px;
}

/* === 数据卡片 - 第 4 个卡(预警)特殊样式 === */
.stat-card .value.danger {
  color: var(--warn);
}

/* === 今日课表列表 === */
.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.schedule-list .list-item {
  background: var(--cream);
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 14px 16px;
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 0;
}

.schedule-time {
  font-family: var(--font-num);
  font-size: 22px;
  color: var(--ink);
  min-width: 64px;
  flex-shrink: 0;
  line-height: 1;
  letter-spacing: -0.5px;
  position: relative;
}

/* 时间右侧细分割线 */
.schedule-time::after {
  content: "";
  position: absolute;
  right: -7px;
  top: 50%;
  transform: translateY(-50%);
  width: 1px;
  height: 28px;
  background: var(--line);
}

.schedule-info {
  flex: 1;
  min-width: 0;
  padding-left: 8px;
}

.schedule-name {
  font-size: 15px;
  font-weight: 500;
  color: var(--ink);
  display: block;
  margin-bottom: 3px;
  letter-spacing: 0.3px;
}

.schedule-meta {
  font-size: 11px;
  color: var(--ink-soft);
  display: block;
  font-family: var(--font-mono);
  letter-spacing: 0.3px;
}

.schedule-action {
  flex-shrink: 0;
}

.schedule-action .btn-primary.small {
  background: var(--ink);
  color: var(--paper);
  border: none;
  padding: 8px 16px;
  border-radius: 100px;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 1px;
  line-height: 1.4;
  display: inline-block;
}

.schedule-status .tag-success {
  background: transparent;
  color: var(--ink-mute);
  border: 1px solid var(--line);
  padding: 5px 10px;
  border-radius: 100px;
  font-size: 11px;
}

.schedule-status .tag-success::before {
  content: "✓ ";
  color: var(--green);
}

/* === 课时预警区 === */
.section:last-of-type .list-item {
  background: linear-gradient(135deg, #FFF4E6 0%, #FFEBD4 100%);
  border: 1px solid var(--warn-border);
  border-radius: 14px;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}

.student-warning-name {
  flex: 1;
  font-size: 14px;
  font-weight: 500;
  color: var(--warn-text);
  font-family: var(--font-serif);
  letter-spacing: 0.5px;
}

.section:last-of-type .tag-danger {
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid var(--warn-border);
  color: var(--warn-text);
  padding: 4px 10px;
  border-radius: 100px;
  font-size: 11px;
  font-weight: 500;
}

/* === 骨架屏 === */
.loading-state .stat-card {
  background: var(--paper-warm);
  border-color: var(--line-soft);
}

.loading-state .stat-card.skeleton .value {
  color: var(--ink-mute);
  font-family: var(--font-num);
}

.loading-state .stat-card.skeleton .label {
  color: var(--ink-mute);
}

.skeleton {
  opacity: 0.6;
}

/* === 空状态(覆盖默认在卡片内的处理) === */
.section .empty-state {
  background: var(--cream);
  border: 1px dashed var(--line);
  border-radius: 14px;
  padding: 32px 22px;
}

.section .empty-text {
  font-size: 13px;
  color: var(--ink-soft);
  font-family: var(--font-sans);
}
