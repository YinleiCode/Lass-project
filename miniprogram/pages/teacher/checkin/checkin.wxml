<view class="container">
  <view wx:if="{{loading}}" class="empty-state">正在校准声场...</view>

  <block wx:else>
    <view class="checkin-hero">
      <view class="checkin-hero-text">
        <text class="art-kicker">点名谱记 · ATTENDANCE</text>
        <text class="art-note">记录一次到场，也校准今天的课后方向。</text>
      </view>
      <view class="checkin-art-frame">
        <image class="checkin-face" src="/images/hero-checkin.png" mode="aspectFit"></image>
      </view>
    </view>

    <!-- 课程信息 -->
    <view class="card checkin-course-card" wx:if="{{schedule}}">
      <view class="schedule-header">
        <text class="schedule-time">{{schedule.start_time}}</text>
        <text class="schedule-pkg">{{schedule.package_name || '课程'}}</text>
      </view>
      <view class="schedule-meta-line">
        <text>{{schedule.class_display || schedule.class_type_label || '课程'}}</text>
        <text wx:if="{{schedule.duration_text}}">{{schedule.duration_text}}</text>
        <text>{{schedule.delivery_mode_label || '线下课'}}</text>
      </view>
      <view class="schedule-teacher">授课老师：{{schedule.teacher_name || '授课老师'}}</view>
      <view class="schedule-hint">默认到课 · 请假 / 缺勤不扣课时</view>
    </view>

    <!-- 学员点名列表 -->
    <view class="student-list">
      <view class="checkin-item" wx:for="{{students}}" wx:key="_id">
        <view class="student-info">
          <view class="avatar {{item.checkinStatus === 'absent' ? 'absent' : (item.checkinStatus === 'leave' ? 'leave' : '')}}">{{item.name[0] || '?'}}</view>
          <view class="info">
            <text class="name">{{item.name}}</text>
            <text wx:if="{{item.leaveTag}}" class="tag tag-warning">{{item.leaveTag}}</text>
            <text class="tag {{item.usableRemaining <= 0 ? 'tag-danger' : (item.usableRemaining <= 3 ? 'tag-warning' : '')}}">{{item.balanceTag}}</text>
            <text wx:if="{{item.totalRemaining > item.remaining}}" class="balance-note">全部余课 {{item.totalRemaining}} 节</text>
          </view>
        </view>

        <view class="status-selector">
          <view class="status-btn {{item.checkinStatus === 'present' ? 'active present' : ''}}" data-id="{{item._id}}" data-status="present" bindtap="setStatus">到课</view>
          <view class="status-btn {{item.checkinStatus === 'absent' ? 'active absent' : ''}}" data-id="{{item._id}}" data-status="absent" bindtap="setStatus">缺勤</view>
          <view class="status-btn {{item.checkinStatus === 'leave' ? 'active leave' : ''}}" data-id="{{item._id}}" data-status="leave" bindtap="setStatus">请假</view>
        </view>
      </view>
    </view>

    <!-- 课时扣减预览 -->
    <view class="deduct-preview">
      <text>本次将写入 <text class="deduct-num">{{deductCount}}</text> 次到课</text>
    </view>

    <!-- 操作按钮 -->
    <view class="action-area">
      <button class="btn-primary" bindtap="onConfirm" loading="{{submitting}}" disabled="{{submitting || !schedule || students.length === 0}}">提交点名</button>

      <button wx:if="{{canUndo}}" class="btn-secondary undo-btn" bindtap="onUndo" loading="{{undoLoading}}" disabled="{{undoLoading || submitting}}">撤销点名</button>
    </view>
  </block>

  <view class="sheet-mask" wx:if="{{showConfirmSheet}}" bindtap="hideConfirmSheet"></view>
  <view class="confirm-sheet {{showConfirmSheet ? 'show' : ''}}" wx:if="{{showConfirmSheet}}">
    <view class="sheet-handle"></view>
    <view class="sheet-head">
      <text class="sheet-title">确认提交点名</text>
      <text class="sheet-desc">提交后将立即写入考勤并扣减课时</text>
    </view>

    <view class="deduct-final">
      <text class="deduct-label">最终扣减</text>
      <view class="deduct-value-row">
        <text class="deduct-value">{{confirmStats.deduct}}</text>
        <text class="deduct-unit">课时</text>
      </view>
    </view>

    <view class="confirm-stats">
      <view class="confirm-stat present">
        <text class="confirm-num">{{confirmStats.present}}</text>
        <text class="confirm-label">到课</text>
      </view>
      <view class="confirm-stat absent">
        <text class="confirm-num">{{confirmStats.absent}}</text>
        <text class="confirm-label">缺勤</text>
      </view>
      <view class="confirm-stat leave">
        <text class="confirm-num">{{confirmStats.leave}}</text>
        <text class="confirm-label">请假</text>
      </view>
    </view>

    <view class="sheet-actions">
      <button class="btn-primary" bindtap="submitAttendance" loading="{{submitting}}" disabled="{{submitting || !schedule || students.length === 0}}">确认扣减并提交</button>
      <button class="btn-secondary" bindtap="hideConfirmSheet" disabled="{{submitting}}">返回修改</button>
    </view>
  </view>
</view>
