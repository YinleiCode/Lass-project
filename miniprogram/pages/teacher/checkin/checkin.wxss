.schedule-header {
  margin-bottom: 8rpx;
}

.schedule-time {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.schedule-pkg {
  font-size: 26rpx;
  color: #999;
  margin-top: 4rpx;
}

.schedule-hint {
  font-size: 24rpx;
  color: #FF9800;
  background: #FFF8E1;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

.student-list {
  margin-bottom: 20rpx;
}

.checkin-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.student-info {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #EBF3FC;
  color: #4A90D9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.avatar.absent {
  background: #FFEBEE;
  color: #F44336;
}

.avatar.leave {
  background: #FFF3E0;
  color: #FF9800;
}

.info {
  flex: 1;
  margin-left: 16rpx;
}

.info .name {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
}

.info .remaining {
  font-size: 22rpx;
}

.info .tag-danger {
  background: #FFEBEE;
  color: #F44336;
}

.status-selector {
  display: flex;
  gap: 12rpx;
}

.status-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  background: #F5F5F5;
  color: #999;
}

.status-btn.active.present {
  background: #E8F5E9;
  color: #4CAF50;
  font-weight: bold;
}

.status-btn.active.absent {
  background: #FFEBEE;
  color: #F44336;
  font-weight: bold;
}

.status-btn.active.leave {
  background: #FFF3E0;
  color: #FF9800;
  font-weight: bold;
}

.deduct-preview {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.deduct-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #4A90D9;
}

.action-area {
  margin-top: 20rpx;
}

.action-area .btn-primary {
  width: 100%;
  margin-bottom: 16rpx;
}

.undo-btn {
  width: 100%;
  font-size: 26rpx;
}
