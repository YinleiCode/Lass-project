/* ============================================================
 *  teacher/checkin — 点名
 * ============================================================ */

/* === 课程信息卡(深色) === */
.container > .card:first-of-type {
  background: var(--ink);
  color: var(--paper);
  border: 1px solid var(--ink);
  border-radius: 16px;
  padding: 18px 20px;
  margin-bottom: 18px;
  position: relative;
  overflow: hidden;
}

.container > .card:first-of-type::before {
  content: "";
  position: absolute;
  right: -20px;
  top: -20px;
  width: 120px;
  height: 120px;
  background: radial-gradient(circle, rgba(191, 209, 229, 0.16) 0%, transparent 70%);
}

.schedule-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 10px;
  position: relative;
  z-index: 1;
}

.schedule-header .schedule-time {
  font-family: var(--font-num);
  font-size: 26px;
  color: var(--paper);
  letter-spacing: -0.5px;
  line-height: 1;
}

.schedule-header .schedule-pkg {
  font-family: var(--font-mono);
  font-size: 11px;
  color: rgba(244, 247, 250, 0.65);
  letter-spacing: 1px;
  text-transform: uppercase;
}

.schedule-hint {
  font-size: 12px;
  color: rgba(244, 247, 250, 0.55);
  font-family: var(--font-mono);
  letter-spacing: 0.3px;
  position: relative;
  z-index: 1;
}

/* === 点名列表 === */
.student-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 22px;
}

.checkin-item {
  background: var(--cream);
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 14px 16px;
}

.student-info {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

.student-info .avatar {
  width: 40px;
  height: 40px;
  border-radius: 14px;
  background: linear-gradient(135deg, var(--accent), var(--accent-mid));
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-serif);
  font-size: 16px;
  font-weight: 600;
  flex-shrink: 0;
  transition: background 0.2s;
}

.student-info .avatar.absent {
  background: linear-gradient(135deg, var(--red), #DC2626);
}

.student-info .avatar.leave {
  background: linear-gradient(135deg, var(--warn), #F59E0B);
}

.info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.info .name {
  font-size: 15px;
  font-weight: 500;
  color: var(--ink);
  letter-spacing: 0.3px;
}

.info .tag-danger {
  align-self: flex-start;
}

/* === 状态选择器 === */
.status-selector {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 6px;
}

.status-btn {
  text-align: center;
  padding: 9px 0;
  font-size: 12px;
  font-weight: 500;
  border-radius: 100px;
  background: var(--paper-warm);
  color: var(--ink-soft);
  border: 1px solid var(--line);
  letter-spacing: 1px;
  transition: all 0.15s;
}

.status-btn.active.present {
  background: var(--green-bg);
  color: var(--green);
  border-color: var(--green);
}

.status-btn.active.absent {
  background: var(--red-bg);
  color: var(--red);
  border-color: var(--red);
}

.status-btn.active.leave {
  background: var(--warn-bg);
  color: var(--warn-text);
  border-color: var(--warn-border);
}

/* === 扣减预览 === */
.deduct-preview {
  background: linear-gradient(135deg, var(--accent-bg) 0%, #DCE9F5 100%);
  border: 1px solid var(--accent-soft);
  border-radius: 14px;
  padding: 14px 18px;
  text-align: center;
  margin-bottom: 22px;
  font-size: 13px;
  color: var(--ink);
  letter-spacing: 0.3px;
}

.deduct-num {
  font-family: var(--font-num);
  font-size: 22px;
  color: var(--accent);
  font-weight: 500;
  margin: 0 4px;
  letter-spacing: -0.5px;
}

/* === 操作区 === */
.action-area {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.action-area .btn-primary {
  width: 100%;
  letter-spacing: 2px;
}

.action-area .btn-secondary,
.undo-btn {
  width: 100%;
  background: var(--cream);
  color: var(--red);
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 12px;
  font-size: 13px;
  letter-spacing: 0.5px;
}
