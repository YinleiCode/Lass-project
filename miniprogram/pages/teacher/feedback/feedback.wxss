/* ============================================================
 *  teacher/feedback — 课后回声
 * ============================================================ */

.feedback-page {
  padding-bottom: 230rpx;
}

.feedback-hero {
  min-height: 210rpx;
  background:
    radial-gradient(circle at 82% 10%, rgba(237, 167, 219, 0.50) 0, transparent 220rpx),
    radial-gradient(circle at 8% 92%, rgba(255, 255, 255, 0.86) 0, transparent 250rpx),
    linear-gradient(145deg, rgba(255, 246, 252, 0.96), rgba(245, 237, 243, 0.86));
  border-radius: 38rpx;
  padding: 34rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  position: relative;
  overflow: hidden;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.82), 0 18rpx 42rpx rgba(181, 107, 162, 0.08);
  box-sizing: border-box;
}

.feedback-hero::before {
  content: "";
  position: absolute;
  right: -84rpx;
  bottom: -126rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(108, 45, 88, 0.08);
}

.feedback-hero-copy {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
}

.feedback-hero-title {
  display: block;
  margin: 14rpx 0 14rpx;
  font-size: 44rpx;
  line-height: 1.08;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: 0;
}

.feedback-hero .art-note {
  max-width: 430rpx;
  color: var(--ink-soft);
}

.feedback-progress {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 36% 24%, rgba(255, 255, 255, 0.96), transparent 52%),
    rgba(255, 255, 255, 0.62);
  box-shadow: inset 0 0 0 2rpx rgba(108, 45, 88, 0.055), 0 14rpx 30rpx rgba(181, 107, 162, 0.10);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.progress-num {
  font-size: 34rpx;
  font-weight: 900;
  color: var(--ink);
  line-height: 1;
}

.progress-label {
  margin-top: 8rpx;
  font-size: 18rpx;
  color: var(--ink-soft);
  font-weight: 800;
}

.context-empty-card,
.feedback-course-card,
.score-panel,
.audio-card {
  background: rgba(255, 255, 255, 0.78);
  border-radius: 30rpx;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.76), 0 12rpx 32rpx rgba(181, 107, 162, 0.07);
  box-sizing: border-box;
}

.context-empty-card {
  padding: 34rpx;
}

.context-empty-title {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  color: var(--ink);
  margin-bottom: 12rpx;
}

.context-empty-desc {
  display: block;
  font-size: 26rpx;
  line-height: 1.55;
  color: var(--ink-soft);
  margin-bottom: 28rpx;
}

.context-empty-btn {
  width: 100%;
}

.feedback-course-card {
  padding: 26rpx 30rpx;
  margin-bottom: 30rpx;
  background:
    radial-gradient(circle at 92% 6%, rgba(237, 167, 219, 0.20) 0, transparent 210rpx),
    rgba(255, 255, 255, 0.76);
}

.feedback-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.feedback-title {
  display: block;
  font-size: 32rpx;
  font-weight: 900;
  color: var(--ink);
  line-height: 1.25;
}

.feedback-date {
  flex-shrink: 0;
  padding-top: 4rpx;
  font-size: 21rpx;
  color: var(--ink-mute);
  font-weight: 800;
  text-align: right;
  line-height: 1.35;
}

.current-student {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--ink-soft);
  font-weight: 800;
  letter-spacing: 1rpx;
}

.feedback-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding-top: 18rpx;
}

.feedback-meta-row text {
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(237, 167, 219, 0.20);
  color: var(--ink-soft);
  font-size: 21rpx;
  font-weight: 850;
  display: inline-flex;
  align-items: center;
}

.student-switch {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  padding: 20rpx 0 2rpx;
}

.student-switch::-webkit-scrollbar {
  display: none;
}

.switch-item {
  flex-shrink: 0;
  min-height: 62rpx;
  padding: 0 28rpx;
  background: rgba(255, 255, 255, 0.72);
  color: var(--ink-soft);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 850;
  display: flex;
  align-items: center;
  box-shadow: inset 0 0 0 2rpx rgba(108, 45, 88, 0.05);
}

.switch-item.active {
  background: var(--ink);
  color: white;
  box-shadow: 0 10rpx 24rpx rgba(108, 45, 88, 0.16);
}

.feedback-section {
  margin-bottom: 34rpx;
}

.feedback-section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 24rpx;
  margin-bottom: 18rpx;
}

.feedback-section-title {
  display: block;
  font-size: 36rpx;
  font-weight: 900;
  color: var(--ink);
  line-height: 1.1;
  letter-spacing: 0;
}

.feedback-section-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--ink-mute);
  font-weight: 800;
}

.score-pill,
.section-link {
  flex-shrink: 0;
  min-height: 56rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  color: var(--ink-soft);
  font-size: 22rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  box-shadow: inset 0 0 0 2rpx rgba(108, 45, 88, 0.05);
}

.section-link {
  color: var(--ink);
  background: rgba(237, 167, 219, 0.34);
}

.score-panel {
  padding: 10rpx 30rpx;
}

.template-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 18rpx;
  flex-wrap: wrap;
}

.template-btn {
  min-height: 70rpx;
  padding: 0 28rpx;
  background:
    radial-gradient(circle at 30% 18%, rgba(255, 255, 255, 0.88), transparent 54%),
    rgba(255, 255, 255, 0.80);
  color: var(--ink);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 900;
  display: inline-flex;
  align-items: center;
  box-shadow: inset 0 0 0 2rpx rgba(108, 45, 88, 0.04), 0 8rpx 22rpx rgba(181, 107, 162, 0.055);
}

.template-btn:active {
  background: rgba(237, 167, 219, 0.62);
}

.comment-input {
  width: 100%;
  min-height: 236rpx;
  background:
    radial-gradient(circle at 88% 4%, rgba(237, 167, 219, 0.14) 0, transparent 190rpx),
    rgba(255, 255, 255, 0.82);
  border-radius: 30rpx;
  padding: 30rpx;
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.6;
  font-weight: 650;
  box-sizing: border-box;
  box-shadow: inset 0 0 0 2rpx rgba(108, 45, 88, 0.045), 0 12rpx 30rpx rgba(181, 107, 162, 0.045);
}

.audio-card {
  padding: 12rpx 24rpx;
}

.feedback-save-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 18rpx 44rpx calc(24rpx + env(safe-area-inset-bottom));
  background:
    linear-gradient(180deg, rgba(251, 248, 247, 0), rgba(251, 248, 247, 0.94) 24rpx, rgba(251, 248, 247, 0.98));
  box-sizing: border-box;
}

.save-hint {
  display: block;
  margin-bottom: 12rpx;
  color: var(--ink-soft);
  font-size: 22rpx;
  text-align: center;
  font-weight: 850;
}

.save-btn {
  width: 100%;
  min-height: 92rpx;
  margin: 0;
  letter-spacing: 1rpx;
}

.save-btn.ready {
  box-shadow: 0 18rpx 38rpx rgba(181, 107, 162, 0.18);
}

.save-btn.disabled,
.save-btn[disabled] {
  background: rgba(217, 198, 210, 0.48) !important;
  color: rgba(53, 17, 38, 0.38) !important;
  box-shadow: none !important;
}

.save-btn.disabled::after,
.save-btn[disabled]::after {
  border: none;
}
