.feedback-header {
  margin-bottom: 16rpx;
}

.feedback-title {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
}

.feedback-date {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.student-switch {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.switch-item {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #F0F0F0;
  color: #666;
}

.switch-item.active {
  background: #4A90D9;
  color: #fff;
}

.current-student {
  font-size: 28rpx;
  font-weight: bold;
  color: #4A90D9;
  display: block;
}

.template-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.template-btn {
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  background: #EBF3FC;
  color: #4A90D9;
  border: 1rpx solid #4A90D9;
}

.comment-input {
  width: 100%;
  min-height: 180rpx;
  background: #F9F9F9;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.save-btn {
  width: 100%;
  margin-top: 20rpx;
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  color: #333;
}
