/* ============================================================
 *  teacher/feedback — 课后反馈
 * ============================================================ */

/* === 课程信息卡 === */
.container > .card:first-of-type {
  background: var(--cream);
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 16px 18px;
  margin-bottom: 22px;
}

.feedback-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--line-soft);
}

.feedback-title {
  font-family: var(--font-serif);
  font-size: 17px;
  font-weight: 600;
  color: var(--ink);
  letter-spacing: 0.5px;
}

.feedback-date {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-mute);
  letter-spacing: 0.5px;
}

/* === 学员切换 tabs === */
.student-switch {
  display: flex;
  gap: 6px;
  overflow-x: auto;
  padding: 2px 0;
  margin-bottom: 12px;
}

.student-switch::-webkit-scrollbar {
  display: none;
}

.switch-item {
  flex-shrink: 0;
  padding: 6px 14px;
  background: var(--paper-warm);
  color: var(--ink-soft);
  border-radius: 100px;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.3px;
  border: 1px solid var(--line);
}

.switch-item.active {
  background: var(--ink);
  color: var(--paper);
  border-color: var(--ink);
}

.current-student {
  display: block;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--accent);
  letter-spacing: 1px;
  text-transform: uppercase;
}

/* === 评语模板 === */
.template-row {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
  flex-wrap: wrap;
}

.template-btn {
  padding: 6px 14px;
  background: var(--accent-bg);
  color: var(--accent);
  border: 1px solid var(--accent-soft);
  border-radius: 100px;
  font-size: 12px;
  font-weight: 500;
}

.template-btn:active {
  background: var(--accent);
  color: white;
}

/* === 评语输入框 === */
.comment-input {
  width: 100%;
  background: var(--cream);
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 14px 16px;
  font-size: 14px;
  color: var(--ink);
  line-height: 1.6;
  min-height: 120px;
  font-family: var(--font-sans);
  box-sizing: border-box;
}

/* === 保存按钮 === */
.save-btn {
  width: 100%;
  margin-top: 8px;
  letter-spacing: 2px;
}
