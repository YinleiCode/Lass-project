/* ============================================================
 *  teacher/profile — 老师个人中心
 * ============================================================ */

/* === 通用卡片(覆盖部分全局卡) === */
.section .card {
  padding: 0;
  overflow: hidden;
}

.section .card .form-item {
  padding: 14px 18px;
  border-bottom: 1px solid var(--line-soft);
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.section .card .form-item:last-of-type {
  border-bottom: none;
}

.section .card .form-item .label {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-mute);
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.section .card .form-item .input {
  font-size: 15px;
  color: var(--ink);
  padding: 6px 0;
  border: none;
  background: transparent;
  outline: none;
  min-height: 24px;
}

.section .card .btn-primary {
  width: calc(100% - 36px);
  margin: 10px 18px 16px;
  letter-spacing: 2px;
}

/* === 邀请码区块 === */
.invite-section {
  padding: 18px;
  text-align: center;
}

.invite-title {
  font-family: var(--font-serif);
  font-size: 15px;
  font-weight: 600;
  color: var(--ink);
  display: block;
  margin-bottom: 6px;
  letter-spacing: 0.5px;
}

.invite-desc {
  font-size: 12px;
  color: var(--ink-soft);
  display: block;
  margin-bottom: 14px;
  letter-spacing: 0.3px;
}

.invite-section .btn-secondary {
  background: var(--accent-bg);
  color: var(--accent);
  border: 1px solid var(--accent-soft);
  padding: 10px 22px;
  font-size: 13px;
  letter-spacing: 1px;
}

/* === 课程包列表 === */
.section .card .pkg-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 18px;
}

.pkg-info {
  flex: 1;
  min-width: 0;
}

.pkg-name {
  font-size: 15px;
  font-weight: 500;
  color: var(--ink);
  display: block;
  margin-bottom: 4px;
  letter-spacing: 0.3px;
}

.pkg-meta {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-mute);
  letter-spacing: 0.5px;
}

.pkg-price {
  font-family: var(--font-num);
  font-size: 20px;
  color: var(--accent);
  letter-spacing: -0.3px;
}

/* "+ 新增"按钮 */
.section-title .more {
  font-size: 12px;
  color: var(--accent);
  font-weight: 500;
  letter-spacing: 0.5px;
}

/* === 弹窗(继承 calendar 的样式) === */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(42, 55, 68, 0.45);
  backdrop-filter: blur(6px);
  z-index: 100;
}

.modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: calc(100% - 44px);
  max-height: 80vh;
  background: var(--cream);
  border-radius: 20px;
  z-index: 101;
  display: flex;
  flex-direction: column;
  box-shadow: 0 24px 60px -16px rgba(44, 82, 130, 0.35);
  overflow: hidden;
}

.modal-header {
  padding: 18px 22px 14px;
  border-bottom: 1px solid var(--line-soft);
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: var(--font-serif);
  font-size: 17px;
  font-weight: 600;
  color: var(--ink);
}

.modal-header .close {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--paper-warm);
  color: var(--ink-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
}

.modal-body {
  padding: 8px 22px;
  flex: 1;
  overflow-y: auto;
}

.modal-body .form-item {
  padding: 12px 0;
  border-bottom: 1px solid var(--line-soft);
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.modal-body .form-item:last-child {
  border-bottom: none;
}

.modal-body .form-item .label {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-mute);
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.modal-body .form-item .input,
.modal-body .form-item .picker {
  font-size: 14px;
  color: var(--ink);
  padding: 4px 0;
}

.modal-footer {
  padding: 14px 22px 22px;
  border-top: 1px solid var(--line-soft);
}

.modal-footer .btn-primary {
  width: 100%;
  letter-spacing: 2px;
}

/* === 邀请码展示弹窗 === */
.invite-code-body {
  text-align: center;
  padding: 26px 22px;
}

.invite-code-large {
  display: block;
  font-family: var(--font-num);
  font-size: 48px;
  color: var(--accent);
  letter-spacing: 12px;
  font-weight: 400;
  margin-bottom: 14px;
  padding-left: 12px; /* 视觉居中:抵消最后字符的右间距 */
}

.invite-expiry {
  display: block;
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--ink-soft);
  letter-spacing: 0.5px;
  margin-bottom: 10px;
}

.invite-warning {
  display: block;
  font-size: 12px;
  color: var(--warn);
  letter-spacing: 0.3px;
}
