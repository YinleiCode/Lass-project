.week-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.nav-btn {
  font-size: 40rpx;
  color: #4A90D9;
  padding: 10rpx 20rpx;
  font-weight: bold;
}

.week-label {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.today-btn {
  font-size: 24rpx;
  color: #4A90D9;
  font-weight: normal;
}

.week-days {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 0;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.day-item {
  flex: 1;
  text-align: center;
  padding: 8rpx 0;
  border-radius: 12rpx;
}

.day-item.active {
  background: #4A90D9;
}

.day-item.active .day-weekday,
.day-item.active .day-num {
  color: #fff;
}

.day-item.today .day-num {
  color: #4A90D9;
  font-weight: bold;
}

.day-weekday {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 4rpx;
}

.day-num {
  font-size: 32rpx;
  color: #333;
  display: block;
}

.schedule-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.card-time {
  font-size: 30rpx;
  font-weight: bold;
  color: #4A90D9;
}

.card-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.card-status.pending {
  background: #FFF3E0;
  color: #FF9800;
}

.card-status.done {
  background: #E8F5E9;
  color: #4CAF50;
}

.card-body {
  margin-bottom: 12rpx;
}

.card-students {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.card-classroom {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.card-actions {
  display: flex;
  gap: 12rpx;
}

.btn-primary.small, .btn-secondary.small {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 99;
}

.modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  overflow-y: auto;
  z-index: 100;
  padding: 30rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 34rpx;
  font-weight: bold;
}

.close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}

.modal-body .form-item {
  margin-bottom: 20rpx;
}

.modal-body .label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.modal-body .input {
  font-size: 30rpx;
  color: #333;
  border-bottom: 1rpx solid #F0F0F0;
  padding: 8rpx 0;
}

.picker {
  font-size: 30rpx;
  color: #333;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.radio-label {
  margin-right: 30rpx;
  font-size: 28rpx;
}

.student-check-list {
  max-height: 240rpx;
  overflow-y: auto;
}

.check-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.check-mark {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #DDD;
  text-align: center;
  line-height: 36rpx;
  font-size: 20rpx;
  color: transparent;
}

.check-mark.checked {
  background: #4A90D9;
  border-color: #4A90D9;
  color: #fff;
}

.modal-footer {
  margin-top: 20rpx;
}

.modal-footer .btn-primary {
  width: 100%;
}
