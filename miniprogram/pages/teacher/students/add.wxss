/* ============================================================
 *  teacher/students/add — 新增 / 编辑学员
 * ============================================================ */

.form {
  background: var(--cream);
  border: none;
  border-radius: 34rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.form-item {
  padding: 20rpx 28rpx;
  border-bottom: 2rpx solid var(--line-soft);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item .label {
  font-size: 22rpx;
  color: var(--ink-mute);
  font-family: var(--font-mono);
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.form-item .input,
.form-item .picker,
.form-item .textarea {
  font-size: 28rpx;
  color: var(--ink);
  padding: 8rpx 0;
  background: transparent;
  border: none;
  outline: none;
  min-height: 64rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-item .textarea {
  min-height: 160rpx;
  line-height: 1.5;
}

/* picker placeholder when empty */
.form-item .picker {
  color: var(--ink);
}

/* 标签输入行 */
.tag-input-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.tag-input-row .input {
  flex: 1;
}

.tag-input-row .btn-secondary.small {
  flex-shrink: 0;
  padding: 0 28rpx;
  font-size: 24rpx;
  border-radius: 999rpx;
  background: var(--accent-bg);
  color: var(--ink);
  border: none;
}

/* 已添加的标签行 */
.form-item .tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  background: var(--accent-bg);
  color: var(--ink);
  border: none;
  padding: 0 18rpx 0 24rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.tag-close {
  color: var(--ink-mute);
  font-size: 22rpx;
  min-width: 72rpx;
  min-height: 72rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

/* 保存按钮 */
.save-btn {
  display: block;
  width: 100%;
  margin-top: 16rpx;
  letter-spacing: 4rpx;
}
