/* ============================================================
 *  teacher/students/feedbacks — 学员声音轨迹
 * ============================================================ */

.feedbacks-hero {
  background:
    radial-gradient(circle at 82% 16%, rgba(237, 167, 219, 0.52) 0, transparent 230rpx),
    radial-gradient(circle at 8% 92%, rgba(255, 255, 255, 0.80) 0, transparent 260rpx),
    linear-gradient(145deg, rgba(255, 244, 251, 0.94), rgba(244, 238, 243, 0.80));
  border-radius: 40rpx;
  padding: 36rpx 36rpx 34rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  position: relative;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.76), 0 18rpx 42rpx rgba(108, 45, 88, 0.07);
}

.feedbacks-hero::after {
  content: "";
  position: absolute;
  right: -76rpx;
  top: -96rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(108, 45, 88, 0.08);
}

.feedbacks-title {
  display: block;
  margin-top: 14rpx;
  font-size: 42rpx;
  line-height: 1.18;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: 0;
  position: relative;
  z-index: 1;
}

.feedbacks-hero .art-kicker,
.feedbacks-hero .art-note {
  position: relative;
  z-index: 1;
}

.filter-bar {
  display: flex;
  background: rgba(255, 255, 255, 0.66);
  border-radius: 999rpx;
  padding: 6rpx;
  margin-bottom: 28rpx;
  gap: 8rpx;
  box-shadow: inset 0 0 0 2rpx rgba(108, 45, 88, 0.04), 0 12rpx 30rpx rgba(181, 107, 162, 0.06);
  backdrop-filter: blur(16rpx);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 24rpx;
  font-weight: 850;
  color: var(--ink-soft);
  border-radius: 20rpx;
  letter-spacing: 1rpx;
}

.filter-item.active {
  background: linear-gradient(145deg, rgba(237, 167, 219, 0.82), rgba(255, 240, 250, 0.94));
  color: var(--ink);
  box-shadow: 0 8rpx 20rpx rgba(181, 107, 162, 0.12);
}

.feedback-list {
  padding-bottom: 24rpx;
}

.feedback-item {
  display: flex;
  gap: 24rpx;
  padding: 22rpx 0;
  position: relative;
}

.feedback-item::before {
  content: "";
  position: absolute;
  left: 11rpx;
  top: 56rpx;
  bottom: -28rpx;
  width: 2rpx;
  background: var(--accent-soft);
}

.feedback-item:last-child::before {
  display: none;
}

.record-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.94);
  border: 5rpx solid var(--accent);
  flex-shrink: 0;
  margin-top: 10rpx;
  position: relative;
  z-index: 1;
  box-shadow: 0 0 0 8rpx rgba(237, 167, 219, 0.18);
}

.feedback-content {
  flex: 1;
  min-width: 0;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 32rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 12rpx 32rpx rgba(181, 107, 162, 0.06);
  backdrop-filter: blur(14rpx);
}

.feedback-content:active {
  background: var(--paper-warm);
}

.feedback-date {
  display: block;
  font-size: 22rpx;
  color: var(--ink-mute);
  letter-spacing: 1rpx;
  margin-bottom: 14rpx;
}

.feedback-title {
  display: block;
  font-size: 26rpx;
  color: var(--ink-soft);
  font-weight: 850;
  margin-bottom: 10rpx;
}

.feedback-comment {
  display: block;
  font-size: 28rpx;
  color: var(--ink);
  line-height: 1.58;
  margin-bottom: 16rpx;
}

.record-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.record-tags .tag {
  background: var(--accent-bg);
  color: var(--ink);
  border: none;
  padding: 6rpx 18rpx;
  border-radius: 200rpx;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}
