/* ============================================================
 *  teacher/students/detail — 学员详情
 * ============================================================ */

/* === 学员信息主卡(深色 ink 主题) === */
.container > .card:first-of-type {
  background: var(--ink);
  color: var(--paper);
  border: 1px solid var(--ink);
  border-radius: 20px;
  padding: 20px 22px;
  position: relative;
  overflow: hidden;
}

.container > .card:first-of-type::before {
  content: "";
  position: absolute;
  right: -30px;
  top: -30px;
  width: 140px;
  height: 140px;
  background: radial-gradient(circle, rgba(191, 209, 229, 0.18) 0%, transparent 70%);
  pointer-events: none;
}

.student-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 14px;
  position: relative;
  z-index: 1;
}

.student-header .avatar {
  width: 56px;
  height: 56px;
  border-radius: 18px;
  background: linear-gradient(135deg, var(--accent-mid), var(--accent));
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-serif);
  font-size: 22px;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 4px 12px -4px rgba(0, 0, 0, 0.3);
}

.student-meta {
  flex: 1;
  min-width: 0;
}

.student-name {
  font-family: var(--font-serif);
  font-size: 20px;
  font-weight: 500;
  color: var(--paper);
  letter-spacing: 0.5px;
  display: block;
  margin-bottom: 4px;
}

.student-phone {
  font-family: var(--font-mono);
  font-size: 12px;
  color: rgba(244, 247, 250, 0.65);
  letter-spacing: 0.5px;
  display: block;
}

.student-date {
  font-family: var(--font-mono);
  font-size: 10px;
  color: rgba(244, 247, 250, 0.45);
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-top: 4px;
  display: block;
}

.more-btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(244, 247, 250, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--paper);
  font-size: 18px;
  flex-shrink: 0;
}

.container > .card:first-of-type .tag-row {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-top: 12px;
  position: relative;
  z-index: 1;
}

.container > .card:first-of-type .tag {
  background: rgba(244, 247, 250, 0.12);
  color: var(--paper);
  padding: 3px 10px;
  border-radius: 100px;
  font-size: 11px;
  letter-spacing: 0.5px;
}

.status-badge {
  display: inline-block;
  margin-top: 12px;
  padding: 4px 12px;
  border-radius: 100px;
  font-size: 11px;
  font-family: var(--font-mono);
  letter-spacing: 1px;
  text-transform: uppercase;
  position: relative;
  z-index: 1;
}

.status-badge.active {
  background: rgba(76, 124, 15, 0.18);
  color: #BEF264;
  border: 1px solid rgba(76, 124, 15, 0.3);
}

.status-badge.archived {
  background: rgba(244, 247, 250, 0.08);
  color: rgba(244, 247, 250, 0.5);
  border: 1px solid rgba(244, 247, 250, 0.12);
}

/* === 操作行 === */
.action-row {
  margin: 18px 0 24px;
}

.action-row .btn-primary {
  width: 100%;
  border-radius: 14px;
  padding: 14px;
  letter-spacing: 2px;
}

/* === 课时明细 / 缴费记录 行 === */
.balance-row,
.order-row,
.feedback-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.balance-pkg {
  font-size: 14px;
  font-weight: 500;
  color: var(--ink);
  letter-spacing: 0.3px;
}

.balance-num {
  font-family: var(--font-num);
  font-size: 22px;
  color: var(--accent);
  letter-spacing: -0.5px;
}

.balance-num.warning,
.balance-num.danger {
  color: var(--warn);
}

.balance-detail {
  margin-top: 8px;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-mute);
  letter-spacing: 0.5px;
}

.order-date,
.feedback-date {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-mute);
  letter-spacing: 0.5px;
}

.order-amount {
  font-family: var(--font-num);
  font-size: 18px;
  color: var(--ink);
  letter-spacing: -0.3px;
}

.order-detail {
  display: block;
  margin-top: 6px;
  font-size: 12px;
  color: var(--accent);
  font-weight: 500;
}

.feedback-comment {
  display: block;
  margin-top: 6px;
  font-family: var(--font-serif);
  font-size: 13px;
  color: var(--ink);
  line-height: 1.6;
  letter-spacing: 0.2px;
}
