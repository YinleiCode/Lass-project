<view class="container">
  <view class="form">
    <view class="form-item">
      <text class="label">学员姓名 *</text>
      <input class="input" placeholder="请输入学员姓名" value="{{name}}" bindinput="onNameInput" />
    </view>

    <view class="form-item">
      <text class="label">家长姓名</text>
      <input class="input" placeholder="请输入家长姓名" value="{{parentName}}" bindinput="onParentNameInput" />
    </view>

    <view class="form-item">
      <text class="label">家长手机号 *</text>
      <input class="input" type="number" maxlength="11" placeholder="请输入手机号" value="{{parentPhone}}" bindinput="onPhoneInput" />
    </view>

    <view class="form-item">
      <text class="label">入学日期</text>
      <picker mode="date" value="{{enrollDate}}" bindchange="onDateChange">
        <view class="picker">{{enrollDate}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">标签</text>
      <view class="tag-input-row">
        <input class="input" placeholder="输入标签" value="{{tagInput}}" bindinput="onTagInput" />
        <button class="btn-secondary small" bindtap="addTag" disabled="{{loading}}">添加</button>
      </view>
      <view class="tag-row" wx:if="{{tags.length}}">
        <view class="tag-item" wx:for="{{tags}}" wx:key="*this">
          <text>{{item}}</text>
          <text class="tag-close" bindtap="removeTag" data-tag="{{item}}">×</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="label">备注</text>
      <textarea class="textarea" placeholder="备注信息" value="{{remark}}" bindinput="onRemarkInput"></textarea>
    </view>
  </view>

  <button class="btn-primary save-btn" bindtap="onSave" loading="{{loading}}" disabled="{{loading}}">
    {{isEdit ? '保存修改' : '保存'}}
  </button>
</view>
