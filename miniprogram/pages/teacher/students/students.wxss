/* ============================================================
 *  teacher/students — 学员列表
 * ============================================================ */

.students-hero {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  background:
    radial-gradient(circle at 82% 20%, rgba(237, 167, 219, 0.64) 0, transparent 190rpx),
    linear-gradient(145deg, rgba(255, 255, 255, 0.72), rgba(255, 240, 250, 0.82));
  color: var(--ink);
  border-radius: 38rpx;
  padding: 34rpx 34rpx 30rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.78), 0 18rpx 42rpx rgba(181, 107, 162, 0.08);
  backdrop-filter: blur(16rpx);
}

.students-hero::before {
  content: "";
  position: absolute;
  right: -86rpx;
  top: -110rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(108, 45, 88, 0.07);
}

.students-hero .art-kicker {
  color: var(--ink-mute);
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.students-title {
  display: block;
  font-size: 48rpx;
  line-height: 1.05;
  font-weight: 900;
  letter-spacing: 1rpx;
  position: relative;
  z-index: 1;
}

.students-count {
  font-size: 76rpx;
  line-height: 0.9;
  font-weight: 900;
  color: var(--plum);
  position: relative;
  z-index: 1;
}

.students-hero-side {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex-shrink: 0;
}

.add-student-btn {
  min-width: 138rpx;
  height: 72rpx;
  padding: 0 24rpx 0 20rpx;
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 34% 24%, rgba(255, 255, 255, 0.88), transparent 42%),
    linear-gradient(145deg, rgba(237, 167, 219, 0.88), rgba(181, 107, 162, 0.72));
  color: var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.66), 0 12rpx 26rpx rgba(181, 107, 162, 0.16);
  backdrop-filter: blur(14rpx);
}

.add-student-btn .add-symbol {
  font-size: 42rpx;
  line-height: 1;
  transform: translateY(-1rpx);
}

.add-student-btn .add-label {
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  line-height: 1;
}

/* 标签筛选横滚 */
.tag-scroll {
  white-space: nowrap;
  margin: 0 -32rpx 24rpx;
  padding: 0 32rpx;
}

.tag-row {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.tag-filter {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.7);
  border: none;
  color: var(--ink-soft);
  min-height: 72rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  line-height: 1;
  white-space: nowrap;
}

.tag-filter.active {
  background: linear-gradient(145deg, rgba(237, 167, 219, 0.84), rgba(255, 240, 250, 0.92));
  color: var(--ink);
  border-color: var(--accent);
  box-shadow: 0 8rpx 20rpx rgba(181, 107, 162, 0.12);
}

/* 统计提示 */
.stats-hint {
  font-family: var(--font-mono);
  font-size: 22rpx;
  color: var(--ink-mute);
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.search-bar {
  background: rgba(255, 255, 255, 0.68);
  border: none;
  box-shadow: inset 0 0 0 2rpx rgba(108, 45, 88, 0.04), 0 12rpx 30rpx rgba(181, 107, 162, 0.06);
  backdrop-filter: blur(16rpx);
}

.search-mark {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--accent-bg);
  color: var(--ink);
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
  flex-shrink: 0;
}
