/* ============================================================
 *  teacher/students — 学员列表
 * ============================================================ */

/* 标签筛选横滚 */
.tag-scroll {
  white-space: nowrap;
  margin: 0 -22px 16px;
  padding: 0 22px;
}

.tag-row {
  display: inline-flex;
  gap: 8px;
  padding: 2px 0;
}

.tag-filter {
  flex-shrink: 0;
  background: var(--cream);
  border: 1px solid var(--line);
  color: var(--ink-soft);
  padding: 6px 14px;
  border-radius: 100px;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.5px;
  white-space: nowrap;
}

.tag-filter.active {
  background: var(--ink);
  color: var(--paper);
  border-color: var(--ink);
}

/* 统计提示 */
.stats-hint {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-mute);
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-bottom: 14px;
  padding-left: 4px;
}

/* 搜索框 emoji 适配 */
.search-bar text {
  font-size: 14px;
  color: var(--ink-mute);
}
