<view class="container" wx:if="{{loading}}">
  <view class="empty-state">正在翻开学员档案...</view>
</view>

<view class="container" wx:else>
  <!-- 学员信息卡片 -->
  <view class="card" wx:if="{{student}}">
    <view class="student-header">
      <view class="avatar">{{avatarText}}</view>
      <view class="student-meta">
        <text class="student-name">{{studentName}}</text>
        <text class="student-phone">{{studentPhone}}</text>
        <text class="student-date" wx:if="{{enrollDateText}}">{{enrollDateText}}</text>
        <text class="student-owner" wx:if="{{isAdmin && ownerTeacherText}}">{{ownerTeacherText}}</text>
        <text class="student-owner" wx:if="{{isAdmin && accessTeacherText}}">{{accessTeacherText}}</text>
      </view>
      <view class="more-btn" bindtap="goEdit">
        <text>⋯</text>
      </view>
    </view>

    <view class="tag-row" wx:if="{{student.tags && student.tags.length}}">
      <text class="tag" wx:for="{{student.tags}}" wx:key="*this">{{item}}</text>
    </view>

    <view class="status-badge {{statusClass}}">
      {{statusText}}
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-grid">
    <view class="stat-card">
      <text class="value">{{totalRemaining}}</text>
      <text class="label">剩余课时</text>
    </view>
    <view class="stat-card">
      <text class="value">{{totalAttended}}</text>
      <text class="label">累计上课</text>
    </view>
    <view class="stat-card" wx:if="{{isAdmin}}">
      <text class="value money-value">{{totalPaidText}}</text>
      <text class="label">累计缴费</text>
    </view>
    <view class="stat-card">
      <text class="value">{{totalFeedbackCount}}</text>
      <text class="label">反馈次数</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-row" wx:if="{{isAdmin}}">
    <button class="btn-primary" bindtap="goPayment">登记缴费</button>
  </view>

  <!-- 课时明细 -->
  <view class="section">
    <view class="section-title"><text>课时明细</text></view>
    <view class="card" wx:for="{{balances}}" wx:key="_id">
      <view class="balance-row">
        <text class="balance-pkg">{{item.packageNameText}}</text>
        <text class="balance-num {{item.balanceClass}}">{{item.remainingText}}</text>
      </view>
      <view class="balance-detail">
        <text>{{item.detailText}}</text>
      </view>
    </view>
    <view wx:if="{{balances.length === 0}}" class="empty-state">
      <text class="empty-text">{{isAdmin ? '暂无课时, 请先登记缴费' : '暂无课时'}}</text>
    </view>
  </view>

  <!-- 缴费记录 -->
  <view class="section" wx:if="{{isAdmin}}">
    <view class="section-title">
      <text>最近缴费</text>
      <text class="more" bindtap="goAllOrders">全部 ›</text>
    </view>
    <view class="card" wx:for="{{orders}}" wx:key="_id">
      <view class="order-row">
        <text class="order-date">{{item.payDateText}}</text>
        <text class="order-amount">{{item.amountText}}</text>
      </view>
      <text class="order-detail">{{item.courseCountText}}</text>
    </view>
    <view wx:if="{{orders.length === 0}}" class="empty-state">
      <text class="empty-text">暂无缴费记录</text>
    </view>
  </view>

  <!-- 最近上课 -->
  <view class="section">
    <view class="section-title">
      <text>最近上课</text>
      <text class="more" bindtap="goAllFeedbacks">全部 ›</text>
    </view>
    <view class="card feedback-card" wx:for="{{feedbacks}}" wx:key="_id" data-scheduleid="{{item.scheduleId}}" bindtap="goFeedback">
      <view class="feedback-row">
        <text class="feedback-date">{{item.dateText}}</text>
        <text class="feedback-comment">{{item.commentPreview}}</text>
      </view>
    </view>
    <view wx:if="{{feedbacks.length === 0}}" class="empty-state">
      <text class="empty-text">暂无上课记录</text>
    </view>
  </view>
</view>
