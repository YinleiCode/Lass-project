/* ============================================================
 *  common/bindparent — 家长绑定
 * ============================================================ */

.container {
  padding: 40px 22px 24px;
  background: linear-gradient(180deg, var(--paper) 0%, var(--paper-warm) 100%);
  min-height: 100vh;
}

.header {
  margin-bottom: 32px;
  text-align: center;
}

.title {
  font-family: var(--font-serif);
  font-size: 28px;
  font-weight: 500;
  color: var(--ink);
  letter-spacing: 4px;
  display: block;
  margin-bottom: 12px;
}

.desc {
  font-size: 13px;
  color: var(--ink-soft);
  line-height: 1.7;
  letter-spacing: 0.3px;
  display: block;
  padding: 0 12px;
}

.form {
  background: var(--cream);
  border: 1px solid var(--line);
  border-radius: 18px;
  overflow: hidden;
  margin-bottom: 22px;
  box-shadow: var(--shadow-sm);
}

.form-item {
  padding: 16px 20px;
  border-bottom: 1px solid var(--line-soft);
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item .label {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink-mute);
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.form-item .input {
  font-size: 16px;
  color: var(--ink);
  padding: 6px 0;
  background: transparent;
  border: none;
  outline: none;
  min-height: 24px;
  letter-spacing: 0.3px;
}

.bind-btn {
  width: 100%;
  letter-spacing: 2px;
}

/* === 提示 === */
.tips {
  margin-top: 22px;
  padding: 12px 16px;
  background: var(--warn-bg);
  border: 1px solid var(--warn-soft);
  border-radius: 12px;
  text-align: center;
}

.tips text {
  font-size: 12px;
  color: var(--warn-text);
  line-height: 1.5;
  letter-spacing: 0.3px;
}
