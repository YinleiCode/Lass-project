/* ============================================================
 *  common/bindparent — 家长绑定
 * ============================================================ */

.container {
  padding: 80rpx 32rpx 48rpx;
  background: linear-gradient(180deg, var(--paper) 0%, var(--accent-bg) 100%);
  min-height: 100vh;
}

.header {
  margin-bottom: 56rpx;
  text-align: center;
}

.title {
  font-family: var(--font-sans);
  font-size: 48rpx;
  font-weight: 500;
  color: var(--ink);
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 20rpx;
}

.desc {
  font-size: 26rpx;
  color: var(--ink-soft);
  line-height: 1.7;
  letter-spacing: 1rpx;
  display: block;
  padding: 0 24rpx;
}

.form {
  background: var(--cream);
  border: 2rpx solid var(--line);
  border-radius: 36rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-sm);
}

.form-item {
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid var(--line-soft);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item .label {
  font-family: var(--font-mono);
  font-size: 22rpx;
  color: var(--ink-mute);
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.form-item .input {
  font-size: 30rpx;
  color: var(--ink);
  padding: 8rpx 0;
  background: transparent;
  border: none;
  outline: none;
  min-height: 64rpx;
  letter-spacing: 1rpx;
}

.bind-btn {
  width: 100%;
  letter-spacing: 4rpx;
}

/* === 提示 === */
.tips {
  margin-top: 32rpx;
  padding: 24rpx 28rpx;
  background: var(--warn-bg);
  border: 2rpx solid var(--warn-soft);
  border-radius: 24rpx;
  text-align: center;
}

.tips text {
  font-size: 24rpx;
  color: var(--warn-text);
  line-height: 1.5;
  letter-spacing: 1rpx;
}
