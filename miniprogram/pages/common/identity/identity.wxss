/* ============================================================
 *  common/identity — 身份选择(进入小程序的第一个页面)
 * ============================================================ */

.identity-page {
  min-height: 100vh;
  padding: 54rpx 34rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background:
    radial-gradient(circle at 86% 12%, rgba(237, 167, 219, 0.3) 0, transparent 240rpx),
    var(--paper);
  position: relative;
}

/* 装饰: 顶部楷体落款 */
.identity-page::before {
  content: "颂恩艺术 · 工作室";
  position: absolute;
  top: 64rpx;
  left: 50%;
  transform: translateX(-50%);
  font-family: var(--font-sans);
  font-size: 26rpx;
  color: var(--ink-mute);
  letter-spacing: 8rpx;
  opacity: 0.6;
}

.identity-hero-img {
  width: 100%;
  height: 360rpx;
  border-radius: 44rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-sm);
}

.identity-kicker {
  margin-bottom: 14rpx;
}

/* Logo */
.logo {
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 34% 24%, rgba(255, 255, 255, 0.86), transparent 42%),
    linear-gradient(145deg, rgba(237, 167, 219, 0.88), rgba(181, 107, 162, 0.72));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 88rpx;
  margin-bottom: 56rpx;
  box-shadow: 0 24rpx 56rpx -24rpx rgba(108, 45, 88, 0.30);
}

.title {
  font-family: var(--font-sans);
  white-space: pre-line;
  font-size: 58rpx;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: 0;
  line-height: 1.02;
  text-align: center;
  margin-bottom: 18rpx;
  display: block;
}

.subtitle {
  font-family: var(--font-mono);
  font-size: 24rpx;
  color: var(--ink-soft);
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 76rpx;
  text-align: center;
  display: block;
}

/* === 角色卡片 === */
.role-cards {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  max-width: 720rpx;
}

.role-card {
  background: var(--cream);
  border: none;
  border-radius: 38rpx;
  padding: 44rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease-in-out;
}

.role-card:nth-child(2) {
  margin-left: 34rpx;
}

.role-index {
  position: absolute;
  right: 34rpx;
  top: 28rpx;
  color: rgba(34, 0, 22, 0.18);
  font-size: 34rpx;
  font-weight: 900;
}

.role-card:active {
  transform: scale(0.985);
  background: var(--accent-bg);
}

.role-card::before {
  content: "";
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(237, 167, 219, 0.38) 0%, transparent 70%);
  pointer-events: none;
}

.role-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: rgba(237, 167, 219, 0.36);
  color: var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 46rpx;
  margin-bottom: 24rpx;
}

.role-name {
  font-family: var(--font-sans);
  font-size: 38rpx;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.role-desc {
  font-size: 24rpx;
  color: var(--ink-soft);
  font-family: var(--font-sans);
  letter-spacing: 2rpx;
}

/* === 邀请码表单 === */
.invite-form {
  width: 100%;
  max-width: 720rpx;
  background: var(--cream);
  border: none;
  border-radius: 38rpx;
  padding: 52rpx 44rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  box-shadow: var(--shadow-md);
}

.form-title {
  font-family: var(--font-sans);
  font-size: 38rpx;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: 2rpx;
  text-align: center;
  display: block;
}

.form-desc {
  font-size: 24rpx;
  color: var(--ink-soft);
  text-align: center;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
  display: block;
}

.invite-form .input {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  line-height: 88rpx;
  background: var(--paper);
  border: none;
  border-radius: 28rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: var(--ink);
  outline: none;
  font-family: var(--font-sans);
  letter-spacing: 1rpx;
  box-sizing: border-box;
  text-align: left;
}

.invite-form .btn-primary {
  width: 100%;
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}

.invite-form .bootstrap-btn {
  width: 100%;
  color: var(--ink);
  background: var(--accent-bg);
  border: none;
}

.btn-link {
  background: transparent;
  border: none;
  color: var(--ink-mute);
  font-size: 24rpx;
  text-align: center;
  letter-spacing: 2rpx;
  padding: 16rpx;
}

.btn-link::after {
  border: none;
}

/* === 加载提示 === */
.loading {
  margin-top: 48rpx;
  font-family: var(--font-mono);
  font-size: 24rpx;
  color: var(--ink-mute);
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.loading::before {
  content: "·";
  display: inline-block;
  margin-right: 16rpx;
  font-size: 44rpx;
  vertical-align: middle;
  color: var(--accent);
  animation: pulse 1.4s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}
