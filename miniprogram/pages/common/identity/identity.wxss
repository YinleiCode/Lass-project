.identity-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #4A90D9 0%, #F6F6F6 50%);
}

.logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 80rpx;
}

.role-cards {
  display: flex;
  gap: 30rpx;
  padding: 0 40rpx;
}

.role-card {
  flex: 1;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 50rpx 30rpx;
  text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

.role-card:active {
  transform: scale(0.97);
}

.role-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.role-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.role-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.loading {
  margin-top: 60rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
}

.invite-form {
  width: 80%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

.form-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
  text-align: center;
}

.form-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 30rpx;
  text-align: center;
}

.invite-form .input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.invite-form .btn-primary {
  width: 100%;
  margin-bottom: 16rpx;
}

.invite-form .btn-link {
  width: 100%;
  background: transparent;
  color: #999;
  font-size: 26rpx;
  border: none;
}
