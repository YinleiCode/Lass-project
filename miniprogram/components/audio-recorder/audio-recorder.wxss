.audio-recorder {
  padding: 16rpx 0;
}

.record-area {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  border: 2rpx dashed #DDD;
}

.record-area.recording {
  background: #FFF0F0;
  border-color: #F44336;
}

.record-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.record-btn.active .record-icon {
  animation: pulse 0.8s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.record-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.record-text {
  font-size: 26rpx;
  color: #666;
}

.audio-row {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.play-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #4A90D9;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.play-btn.active {
  background: #FF9800;
}

.duration {
  flex: 1;
  margin-left: 16rpx;
  font-size: 26rpx;
  color: #666;
}

.del-btn {
  font-size: 24rpx;
  color: #F44336;
  padding: 8rpx 16rpx;
}

.no-audio, .hint {
  font-size: 24rpx;
  color: #BBB;
  text-align: center;
  padding: 16rpx 0;
}
