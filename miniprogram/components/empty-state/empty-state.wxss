/* ============================================================
 *  empty-state — 空状态组件
 * ============================================================ */
.empty-state {
  text-align: center;
  padding: 60px 22px;
}

.empty-state .icon {
  font-size: 44px;
  display: block;
  margin-bottom: 16px;
  opacity: 0.45;
  line-height: 1;
}

.empty-state .text {
  font-family: var(--font-serif);
  font-size: 14px;
  color: var(--ink-soft);
  display: block;
  letter-spacing: 0.5px;
}
