/* ============================================================
 *  empty-state — 空状态组件
 * ============================================================ */
.empty-state {
  text-align: center;
  padding: 120rpx 44rpx;
}

.empty-state .icon {
  font-size: 88rpx;
  display: block;
  margin-bottom: 32rpx;
  opacity: 0.45;
  line-height: 1;
}

.empty-state .text {
  font-family: var(--font-serif);
  font-size: 28rpx;
  color: var(--ink-soft);
  display: block;
  letter-spacing: 1rpx;
}
