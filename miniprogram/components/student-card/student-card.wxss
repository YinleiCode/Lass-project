.student-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #EBF3FC;
  color: #4A90D9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.tags {
  display: flex;
  gap: 8rpx;
}

.tag {
  display: inline-block;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  background: #EBF3FC;
  color: #4A90D9;
}

.meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.meta .phone {
  margin-right: 20rpx;
}

.balance {
  text-align: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.balance .num {
  font-size: 40rpx;
  font-weight: bold;
  color: #4A90D9;
}

.balance .unit {
  font-size: 22rpx;
  color: #999;
  display: block;
}

.balance.warning .num {
  color: #FF9800;
}

.balance.danger .num {
  color: #F44336;
}
