/* ============================================================
 *  student-card — 学员卡片组件
 * ============================================================ */
.student-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.72);
  border: none;
  border-radius: 30rpx;
  padding: 22rpx 26rpx;
  margin-bottom: 16rpx;
  position: relative;
  box-shadow: 0 12rpx 32rpx rgba(181, 107, 162, 0.06);
  overflow: hidden;
  backdrop-filter: blur(14rpx);
}

.student-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  border-radius: 999rpx;
  background: rgba(237, 167, 219, 0.78);
}

.student-card:active {
  background: var(--paper-warm);
}

.student-card .avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #F0A9DE, #F8D8EF);
  color: var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-serif);
  font-size: 32rpx;
  font-weight: 900;
  flex-shrink: 0;
  box-shadow: inset 0 0 0 2rpx rgba(108, 45, 88, 0.08);
}

.info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.name {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: 1rpx;
  max-width: 260rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tags .tag {
  display: inline-block;
  background: var(--accent-bg);
  color: var(--ink);
  padding: 2rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.6;
}

.meta {
  font-family: var(--font-mono);
  font-size: 22rpx;
  color: var(--ink-mute);
  letter-spacing: 1rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  line-height: 1.35;
  min-width: 0;
}

.meta .phone {
  margin-right: 0;
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta .owner {
  color: var(--ink-soft);
}

.balance {
  text-align: right;
  flex-shrink: 0;
  margin-left: 24rpx;
  min-width: 78rpx;
}

.balance .num {
  font-family: var(--font-num);
  font-size: 44rpx;
  font-weight: 900;
  color: var(--ink);
  line-height: 1;
  letter-spacing: 0;
}

.balance .unit {
  font-family: var(--font-mono);
  font-size: 20rpx;
  color: var(--ink-mute);
  display: block;
  margin-top: 8rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.balance.warning .num {
  color: #D8842A;
}

.balance.danger .num {
  color: #D8842A;
  font-weight: 500;
}

.balance.danger {
  position: relative;
}

.balance.danger::after {
  content: "";
  position: absolute;
  right: -32rpx;
  top: 50%;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #E7A14C;
  transform: translateY(-50%);
}

.card-arrow {
  color: var(--ink-mute);
  font-size: 34rpx;
  margin-left: 12rpx;
  line-height: 1;
  flex-shrink: 0;
}
