<view class="student-card" bindtap="onTap" bindlongpress="onLongPress">
  <view class="avatar">{{student.name[0] || '?'}}</view>
  <view class="info">
    <view class="name-row">
      <text class="name">{{student.name}}</text>
      <view class="tags">
        <text wx:for="{{student.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
    </view>
    <view class="meta">
      <text class="phone">{{student.parent_phone}}</text>
      <text class="date">{{student.enroll_date}}</text>
    </view>
  </view>
  <view class="balance {{balanceClass}}">
    <text class="num">{{remaining}}</text>
    <text class="unit">节</text>
  </view>
</view>
