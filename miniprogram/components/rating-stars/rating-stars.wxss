/* ============================================================
 *  rating-stars — 5 星评分组件
 * ============================================================ */
.rating-stars {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 2rpx solid rgba(108, 45, 88, 0.055);
}

.rating-stars:last-of-type {
  border-bottom: none;
}

.label {
  font-size: 27rpx;
  color: var(--ink);
  width: 188rpx;
  flex-shrink: 0;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1.25;
}

.stars {
  display: flex;
  justify-content: flex-end;
  gap: 6rpx;
  min-width: 0;
  flex: 1;
}

.star {
  width: 54rpx;
  height: 54rpx;
  color: rgba(181, 107, 162, 0.20);
  transition: color 0.15s, transform 0.15s;
  line-height: 1;
  font-size: 46rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-shadow: 0 4rpx 10rpx rgba(255, 255, 255, 0.78);
}

.star.active {
  color: #D95FB9;
  text-shadow: 0 8rpx 18rpx rgba(181, 107, 162, 0.26);
  transform: translateY(-2rpx) scale(1.03);
}
