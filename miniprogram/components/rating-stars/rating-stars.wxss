/* ============================================================
 *  rating-stars — 5 星评分组件
 * ============================================================ */
.rating-stars {
  display: flex;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid var(--line-soft);
}

.rating-stars:last-of-type {
  border-bottom: none;
}

.label {
  font-size: 13px;
  color: var(--ink-soft);
  width: 90px;
  flex-shrink: 0;
  font-weight: 500;
  letter-spacing: 0.5px;
}

.stars {
  display: flex;
  gap: 6px;
}

.star {
  font-size: 20px;
  color: var(--line);
  transition: color 0.15s, transform 0.15s;
  line-height: 1;
}

.star.active {
  color: var(--accent);
}
