/* ============================================================
 *  Tab Bar — 粉黑线描 · 白底图标栏
 * ============================================================ */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.92);
  border-top: none;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
  box-sizing: border-box;
  box-shadow: 0 -18rpx 44rpx rgba(108, 45, 88, 0.08);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: var(--ink);
  font-size: 20rpx;
  letter-spacing: 1rpx;
  position: relative;
  padding: 18rpx 0 12rpx;
}

.tab-icon {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 300;
  line-height: 1;
  opacity: 0.62;
  transition: opacity 0.2s, transform 0.2s;
}

.tab-text {
  font-size: 19rpx;
  color: var(--ink-mute);
  letter-spacing: 1rpx;
  font-family: var(--font-mono);
}

/* 选中态 */
.tab-item.active {
  color: var(--ink);
  background: transparent;
  box-shadow: none;
}

.tab-item.active .tab-icon {
  opacity: 1;
  background:
    radial-gradient(circle at 34% 24%, rgba(255, 255, 255, 0.86), transparent 42%),
    linear-gradient(145deg, rgba(237, 167, 219, 0.86), rgba(255, 240, 250, 0.92));
  color: var(--ink);
  transform: translateY(-4rpx) scale(1.03);
}

.tab-item.active .tab-text {
  color: var(--ink);
  font-weight: 800;
  font-size: 22rpx;
}

/* 底部小圆点 */
.tab-item.active::before {
  content: "";
  position: absolute;
  bottom: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  background: var(--plum-soft);
  border-radius: 50%;
}
